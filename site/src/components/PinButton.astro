---
// PinButton.astro — Per-item pin/unpin button.
//
// Always rendered server-side as a <button> carrying `data-pin-type` and
// `data-pin-slug`. All visibility / label / aria-pressed state is decided
// by the <script> at the bottom of this file, which reads `auth.readToken()`
// and (when signed in) calls into `gist.ts` for pin/unpin operations.
//
// 2026-05-25 late-night UAT redesign:
//   - Signed-out users now SEE the pin icon (was: hidden entirely). Per the
//     listing-page design, the icon hides at row rest and reveals on row hover
//     via a CSS rule on the parent row — see tips.astro / skills.astro.
//   - Clicking the icon while signed-out dispatches `nbgaihub:open-signin-modal`
//     (existing behavior — unchanged).
//   - The button renders as an icon-only square (no "Sign in to pin" label),
//     keeping rows compact. When signed in it shows the pin + tiny label.
//   - An inline SVG pushpin replaces the emoji glyph — emoji renders inconsistently
//     across OSes and clashed with the rest of the UI.
//
// All pin/unpin logic still goes through gist.ts. The button optimistically
// updates the UI before the network call resolves and reverts on failure.

export type PinType = 'news' | 'skill' | 'tip' | 'glossary' | 'journey-step';

interface Props {
  type: PinType;
  slug: string;
  /** When true (the default on listing rows), the button renders as an icon-
   *  only square and is meant to be hover-revealed by the parent row's CSS. */
  iconOnly?: boolean;
}

const { type, slug, iconOnly = true } = Astro.props;
---

<button
  type="button"
  class:list={["nbg-pin", iconOnly && "nbg-pin--icon-only"]}
  data-pin-type={type}
  data-pin-slug={slug}
  data-icon-only={iconOnly ? 'true' : 'false'}
  aria-pressed="false"
  aria-label="Sign in to pin"
  title="Sign in to pin this"
>
  <span class="nbg-pin__icon" aria-hidden="true">
    {/* lucide-style pushpin — clear "this gets pinned" affordance. */}
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 17v5" />
      <path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
    </svg>
  </span>
  <span class="nbg-pin__label">Pin</span>
</button>

<style>
  @layer nbg.components {
    /* When signed-out + iconOnly + hover-reveal is in play, the parent row's
       CSS controls visibility (opacity 0 → 1 on row hover). We keep the
       button in the DOM and let it ride the row's hover state. */
    .nbg-pin {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.65rem;
      border-radius: 8px;
      border: 1px solid var(--nbg-border, #dce3eb);
      background: var(--nbg-surface, #ffffff);
      color: var(--nbg-muted, #5b6b80);
      cursor: pointer;
      font-family: var(--nbg-ff-body);
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1;
      transition:
        background-color 120ms ease,
        color            120ms ease,
        border-color     120ms ease,
        opacity          120ms ease,
        transform        120ms ease;
    }
    .nbg-pin:hover {
      background: var(--nbg-accent-soft, #e0f2f4);
      color: var(--nbg-accent-ink, #00525c);
      border-color: var(--nbg-accent, #007a8a);
    }
    .nbg-pin:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* Icon-only mode — used on listing rows. */
    .nbg-pin--icon-only {
      padding: 0.4rem;
      width: 32px;
      height: 32px;
      justify-content: center;
    }
    .nbg-pin--icon-only .nbg-pin__label {
      /* Visually hide the label but keep it for screen readers. */
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .nbg-pin[aria-pressed='true'] {
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      border-color: var(--nbg-accent, #007a8a);
    }
    .nbg-pin[aria-pressed='true']:hover {
      background: var(--nbg-accent-ink, #00525c);
      color: #ffffff;
      border-color: var(--nbg-accent-ink, #00525c);
    }
    .nbg-pin[disabled] {
      opacity: 0.55;
      cursor: progress;
    }
    .nbg-pin__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }

    /* Hidden state — still controlled by the script for the case where a
       caller passes <PinButton /> outside of a hover-reveal row. */
    .nbg-pin[hidden] { display: none !important; }
  }
</style>

<script>
  // Bundled by Vite as an ES module — same pattern as SocialIconsOverride.astro.
  import { readToken, signOut, subscribe } from '../lib/auth.ts';
  import { TokenInvalidError } from '../lib/api-fetch.ts';
  import {
    findOrCreateFavoritesGist,
    addFavorite,
    removeFavorite,
    type FavoritesDocument,
  } from '../lib/gist.ts';

  type PinType = 'news' | 'skill' | 'tip' | 'glossary' | 'journey-step';

  type PageCache = {
    gistId: string;
    document: FavoritesDocument;
  };

  // Memoised promise of the favourites doc for this page load (one fetch per
  // visit, shared across every button on the page).
  let cachePromise: Promise<PageCache> | null = null;

  function loadFavoritesCache(token: string): Promise<PageCache> {
    if (cachePromise === null) {
      cachePromise = findOrCreateFavoritesGist(token).then((result) => ({
        gistId: result.gistId,
        document: result.document,
      }));
    }
    return cachePromise;
  }

  function resetFavoritesCache(): void {
    cachePromise = null;
  }

  function isPinned(doc: FavoritesDocument, type: PinType, slug: string): boolean {
    return doc.favourites.some((f) => f.type === type && f.slug === slug);
  }

  function setSignedOut(btn: HTMLButtonElement): void {
    // When signed-out, leave the button visible — the parent row controls
    // hover-reveal (rows have CSS `.nbg-pin { opacity: 0 } .row:hover .nbg-pin
    // { opacity: 1 }`). Clicking opens the sign-in modal.
    //
    // The exception is when the button is rendered in non-iconOnly mode
    // outside a listing row — in that case we still hide it (preserving the
    // previous UAT #13 behaviour for places like my-pins/news where pinning
    // doesn't make sense for signed-out users).
    const iconOnly = btn.dataset.iconOnly === 'true';
    if (!iconOnly) {
      btn.hidden = true;
      btn.disabled = false;
      btn.setAttribute('aria-pressed', 'false');
      btn.setAttribute('aria-label', 'Sign in to pin');
      const label = btn.querySelector<HTMLElement>('.nbg-pin__label');
      if (label) label.textContent = 'Sign in to pin';
      return;
    }
    btn.hidden = false;
    btn.disabled = false;
    btn.setAttribute('aria-pressed', 'false');
    btn.setAttribute('aria-label', 'Sign in to pin this');
    btn.setAttribute('title', 'Sign in to pin this');
    const label = btn.querySelector<HTMLElement>('.nbg-pin__label');
    if (label) label.textContent = 'Sign in to pin';
  }

  function setSignedInState(btn: HTMLButtonElement, pinned: boolean): void {
    btn.hidden = false;
    btn.disabled = false;
    btn.setAttribute('aria-pressed', pinned ? 'true' : 'false');
    btn.setAttribute('aria-label', pinned ? 'Unpin' : 'Pin');
    btn.setAttribute('title', pinned ? 'Unpin' : 'Pin');
    const label = btn.querySelector<HTMLElement>('.nbg-pin__label');
    if (label) label.textContent = pinned ? 'Pinned' : 'Pin';
  }

  function getMeta(btn: HTMLButtonElement): { type: PinType; slug: string } | null {
    const type = btn.dataset.pinType as PinType | undefined;
    const slug = btn.dataset.pinSlug;
    if (!type || !slug) return null;
    return { type, slug };
  }

  // UAT T10 V1 — fire-and-forget toast confirmation. Title is read from
  // the nearest listing-row title node when available so the message says
  // *which* item was just pinned; falls back to the generic type label.
  function emitToast(btn: HTMLButtonElement, pinned: boolean): void {
    const row = btn.closest('.listing-row, [data-pin-context]');
    const titleEl = row?.querySelector(
      '.listing-row__title, [data-pin-title]',
    );
    const itemTitle = titleEl?.textContent?.trim() || btn.dataset.pinType || 'item';
    const verb = pinned ? 'Pinned' : 'Unpinned';
    const detail = pinned
      ? {
          title: `${verb} "${itemTitle}"`,
          action: { label: 'View pins', href: '/my-pins/' },
        }
      : { title: `${verb} "${itemTitle}"` };
    try {
      document.dispatchEvent(new CustomEvent('nbgaihub:toast', { detail }));
    } catch (_) {
      /* never throw from a side-effect */
    }
  }

  function onSignedOutClick(event: MouseEvent): void {
    // Don't propagate to the parent <a> (some rows may wrap titles in links)
    event.preventDefault();
    event.stopPropagation();
    document.dispatchEvent(new CustomEvent('nbgaihub:open-signin-modal'));
  }

  function bindSignedOutHandler(btn: HTMLButtonElement): void {
    const existing = (btn as any).__nbgPinHandler as
      | ((e: MouseEvent) => void)
      | undefined;
    if (existing) btn.removeEventListener('click', existing);
    (btn as any).__nbgPinHandler = onSignedOutClick;
    btn.addEventListener('click', onSignedOutClick);
  }

  function bindSignedInHandler(
    btn: HTMLButtonElement,
    token: string,
    cache: PageCache,
  ): void {
    const meta = getMeta(btn);
    if (!meta) return;

    const handler = async (event: MouseEvent): Promise<void> => {
      event.preventDefault();
      event.stopPropagation();
      const currentlyPinned = btn.getAttribute('aria-pressed') === 'true';
      const nextPinned = !currentlyPinned;

      // Optimistic UI flip.
      setSignedInState(btn, nextPinned);
      btn.disabled = true;

      try {
        let updated: FavoritesDocument;
        if (nextPinned) {
          updated = await addFavorite(token, cache.gistId, {
            type: meta.type,
            slug: meta.slug,
            pinned_at: new Date().toISOString().slice(0, 10),
          });
        } else {
          updated = await removeFavorite(token, cache.gistId, {
            type: meta.type,
            slug: meta.slug,
          });
        }
        cache.document = updated;
        btn.disabled = false;
        setSignedInState(btn, isPinned(updated, meta.type, meta.slug));
        // UAT T10 V1 — confirm visibly. The single most-common pin
        // complaint ("I pinned, where is it?") is best answered with an
        // immediate toast plus a one-click path to /my-pins/.
        emitToast(btn, nextPinned);
      } catch (err) {
        setSignedInState(btn, currentlyPinned);
        btn.disabled = false;
        if (err instanceof TokenInvalidError) {
          // Stored token was revoked/expired since the page loaded. Drop
          // it; the auth subscriber re-renders all pin buttons in
          // signed-out mode and the next click opens the sign-in modal.
          signOut();
          return;
        }
        const msg = err instanceof Error ? err.message : String(err);
        btn.title = `Pin failed: ${msg}`;
      }
    };

    const existing = (btn as any).__nbgPinHandler as
      | ((e: MouseEvent) => void)
      | undefined;
    if (existing) btn.removeEventListener('click', existing);
    (btn as any).__nbgPinHandler = handler;
    btn.addEventListener('click', handler);
  }

  function applyAnonymousState(buttons: HTMLButtonElement[]): void {
    for (const btn of buttons) {
      setSignedOut(btn);
      bindSignedOutHandler(btn);
    }
  }

  async function applyAuthenticatedState(
    buttons: HTMLButtonElement[],
    token: string,
  ): Promise<void> {
    // Show buttons immediately in a loading state.
    for (const btn of buttons) {
      btn.hidden = false;
      btn.disabled = true;
      btn.setAttribute('aria-label', 'Loading');
      const label = btn.querySelector<HTMLElement>('.nbg-pin__label');
      if (label) label.textContent = '…';
    }

    let cache: PageCache;
    try {
      cache = await loadFavoritesCache(token);
    } catch (err) {
      resetFavoritesCache();
      if (err instanceof TokenInvalidError) {
        // Stored token is dead. signOut() fires the auth subscriber
        // which re-renders every PinButton in signed-out (hover-reveal)
        // mode — clicking will then open the sign-in modal cleanly.
        signOut();
        return;
      }
      for (const btn of buttons) {
        setSignedInState(btn, false);
        const msg = err instanceof Error ? err.message : String(err);
        btn.title = `Could not load favourites: ${msg}`;
        bindSignedInHandlerWithRetry(btn, token);
      }
      return;
    }

    for (const btn of buttons) {
      const meta = getMeta(btn);
      if (!meta) continue;
      setSignedInState(btn, isPinned(cache.document, meta.type, meta.slug));
      bindSignedInHandler(btn, token, cache);
    }
  }

  function bindSignedInHandlerWithRetry(
    btn: HTMLButtonElement,
    token: string,
  ): void {
    const handler = async (event: MouseEvent): Promise<void> => {
      event.preventDefault();
      event.stopPropagation();
      btn.disabled = true;
      try {
        const cache = await loadFavoritesCache(token);
        const meta = getMeta(btn);
        if (!meta) {
          btn.disabled = false;
          return;
        }
        setSignedInState(btn, isPinned(cache.document, meta.type, meta.slug));
        bindSignedInHandler(btn, token, cache);
      } catch (err) {
        resetFavoritesCache();
        btn.disabled = false;
        const msg = err instanceof Error ? err.message : String(err);
        btn.title = `Could not load favourites: ${msg}`;
      }
    };
    const existing = (btn as any).__nbgPinHandler as
      | ((e: MouseEvent) => void)
      | undefined;
    if (existing) btn.removeEventListener('click', existing);
    (btn as any).__nbgPinHandler = handler;
    btn.addEventListener('click', handler);
  }

  function readAuthState(): { token: string } | null {
    try {
      return readToken();
    } catch {
      return null;
    }
  }

  async function render(buttons: HTMLButtonElement[]): Promise<void> {
    const state = readAuthState();
    if (state === null) {
      resetFavoritesCache();
      applyAnonymousState(buttons);
      return;
    }
    await applyAuthenticatedState(buttons, state.token);
  }

  function collect(): HTMLButtonElement[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>('button[data-pin-type]'),
    );
  }

  function init(): void {
    const buttons = collect();
    if (buttons.length === 0) return;

    void render(buttons);

    subscribe(() => {
      resetFavoritesCache();
      void render(collect());
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
