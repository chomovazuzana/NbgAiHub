---
// AudienceFilter.astro — Single-select segmented audience filter.
//
// 2026-05-25 redesign (UAT feedback #9, #17):
//   - Three checkboxes → three radios (single-select segmented control)
//   - "Both" dropped as a visible option (it's an audience tag, not a
//     filter selector — the user wanted to know whether a tip applies to
//     them, not pick a third bucket).
//   - Active state is now an obvious dark-inverted pill — no more "did
//     anything happen?" guessing.
//
// Filter semantics:
//   "All"        → show every item
//   "Beginner"   → show items tagged beginner OR both
//   "Advanced"   → show items tagged advanced OR both
//
// State is persisted in localStorage.nbgaihub.audience as one of
// 'all' | 'beginner' | 'advanced'. The legacy array-of-strings format
// from the previous checkbox UI is migrated automatically on read.

interface Props {
  scope?: string;
}

const { scope = '[data-audience]' } = Astro.props;
---

<form class="audience-filter not-content" data-scope={scope}>
  <span class="audience-filter__label">Show</span>
  <div class="audience-filter__group" role="radiogroup" aria-label="Audience filter">
    <label class="audience-filter__option">
      <input type="radio" name="audience" value="all" checked />
      <span class="audience-filter__chip">Everything</span>
    </label>
    <label class="audience-filter__option">
      <input type="radio" name="audience" value="beginner" />
      <span class="audience-filter__chip">For beginners</span>
    </label>
    <label class="audience-filter__option">
      <input type="radio" name="audience" value="advanced" />
      <span class="audience-filter__chip">For experienced</span>
    </label>
  </div>
</form>

<style>
  @layer nbg.components {
    .audience-filter {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--nbg-sp-3);
      margin-block: var(--nbg-sp-4);
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      background: var(--nbg-color-bg-surface);
      border: 1px solid var(--nbg-color-border-subtle);
      border-radius: var(--nbg-r-md);
    }
    .audience-filter__label {
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-xs);
      font-weight: var(--nbg-fw-medium);
      letter-spacing: var(--nbg-ls-wide);
      text-transform: uppercase;
      color: var(--nbg-color-fg-muted);
    }
    .audience-filter__group {
      display: inline-flex;
      flex-wrap: wrap;
      gap: var(--nbg-sp-1);
      padding: var(--nbg-sp-1);
      background: var(--nbg-color-bg-page);
      border: 1px solid var(--nbg-color-border-subtle);
      border-radius: var(--nbg-r-pill);
    }
    .audience-filter__option {
      display: inline-flex;
      cursor: pointer;
      position: relative;
    }
    /* Visually hide the real input but keep it focusable for keyboard + AT. */
    .audience-filter__option input[type='radio'] {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      margin: 0;
      opacity: 0;
      cursor: pointer;
    }
    .audience-filter__chip {
      display: inline-flex;
      align-items: center;
      /* --nbg-sp-3-5 was a phantom token (never defined in primitives.css);
       * historically the chip padding-x was 0 and the regression was hidden
       * by the filter's outer bordered chrome. Now that the outer chrome
       * is gone (filter integrated into the hero), use real tokens. */
      padding: 0.4rem 0.9rem;
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-sm);
      font-weight: var(--nbg-fw-medium);
      line-height: 1.3;
      color: var(--nbg-color-fg-secondary);
      background: transparent;
      border-radius: var(--nbg-r-pill);
      transition:
        background-color var(--nbg-dur-fast) var(--nbg-ease-out),
        color            var(--nbg-dur-fast) var(--nbg-ease-out),
        transform        var(--nbg-dur-fast) var(--nbg-ease-out);
      user-select: none;
    }
    .audience-filter__option:hover .audience-filter__chip {
      color: var(--nbg-color-fg-primary);
      background: var(--nbg-color-bg-surface-hover);
    }
    /* Active state — high-contrast dark pill so it's unmistakably "selected".
       Previously a subtle accent-bg tint was used, which was almost invisible
       in the screenshot and made the user think the filter did nothing. */
    .audience-filter__option input[type='radio']:checked + .audience-filter__chip {
      background: var(--nbg-color-fg-primary);
      color: var(--nbg-color-bg-page);
      font-weight: var(--nbg-fw-semibold);
    }
    .audience-filter__option input[type='radio']:focus-visible + .audience-filter__chip {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
  }
</style>

<script is:inline>
  (function () {
    // 2026-05-26: filter no longer persists across pages. The filter is a
    // transient UI choice for the current view (like a search box) — every
    // visit to /skills or /tips starts fresh at "Everything", regardless of
    // what was selected on a previous visit. Per operator: "everything to be
    // default on skills and tips."
    //
    // Within-visit filter changes still work — they just don't survive a
    // page navigation or refresh. Legacy localStorage entries from the old
    // persisted model are cleared on first run so they don't leak back if
    // the script is ever re-pointed at storage.
    const KEY_LEGACY = 'nbgaihub.audience';
    try { localStorage.removeItem(KEY_LEGACY); } catch (_) { /* ignore */ }

    function readSelection() {
      return 'all';
    }

    function writeSelection(_value) {
      // no-op — filter state is per-visit, not persisted.
    }

    function applyAll(value) {
      document.querySelectorAll('.audience-filter').forEach(function (form) {
        const scope = form.getAttribute('data-scope') || '[data-audience]';
        document.querySelectorAll(scope).forEach(function (el) {
          const a = el.getAttribute('data-audience') || 'both';
          let visible;
          if (value === 'all') {
            visible = true;
          } else if (value === 'beginner') {
            visible = a === 'beginner' || a === 'both';
          } else if (value === 'advanced') {
            visible = a === 'advanced' || a === 'both';
          } else {
            visible = true;
          }
          el.classList.toggle('audience-hidden', !visible);
        });
      });
    }

    function syncRadios(value) {
      document
        .querySelectorAll('.audience-filter input[type="radio"]')
        .forEach(function (radio) {
          radio.checked = radio.value === value;
        });
    }

    function init() {
      const current = readSelection();
      syncRadios(current);
      applyAll(current);
      document
        .querySelectorAll('.audience-filter input[type="radio"]')
        .forEach(function (radio) {
          radio.addEventListener('change', function () {
            if (!radio.checked) return;
            writeSelection(radio.value);
            applyAll(radio.value);
          });
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
