---
// NewsList.astro — Full news list for /news/.
// See project-design.md §S.3.3.

import AudienceBadge from './AudienceBadge.astro';
import ConfidenceChip from './ConfidenceChip.astro';
import PinButton from './PinButton.astro';
import { getRecentNews } from '../lib/news.ts';

const items = await getRecentNews();
---

{items.length === 0 ? (
  <p class="empty-state">
    No items yet. See <a href="/contribute/">Contribute</a> for how to add one.
  </p>
) : (
  <div class="news-card-grid">
    {items.map((item) => (
      <article
        class="news-card"
        data-audience={item.data.audience}
        data-topics={item.data.topics.join(',')}
      >
        <h3>
          <a href={`/news/${item.id}/`}>{item.data.title}</a>
        </h3>
        <div class="news-card__meta">
          <AudienceBadge audience={item.data.audience} />
          <ConfidenceChip confidence={item.data.editor_confidence} />
          <span class="news-card__source">{item.data.source}</span>
          <span class="news-card__date">{item.data.authored}</span>
        </div>
        <PinButton type="news" slug={item.id} />
        {item.data.topics.length > 0 && (
          <div class="skill-card__topics">
            {item.data.topics.map((topic) => (
              <span class="topic-chip">{topic}</span>
            ))}
          </div>
        )}
        <p class="news-card__summary">{item.data.ai_summary}</p>
      </article>
    ))}
  </div>
)}
