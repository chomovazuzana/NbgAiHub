---
/**
 * MarketingShell.astro — The Starlight isolation boundary for marketing surfaces.
 *
 * Purpose: ONE shared wrapper for every marketing page (/news, /skills,
 * /tips, /glossary, /reference, /contribute, /start-here/*, /my-pins,
 * /submit-skill, /). Wraps StarlightPage with `template: 'splash'` (drops
 * sidebar + TOC).
 *
 * Header chrome on splash pages is owned by SplashAwareHeader.astro (the
 * `components: { Header }` override in astro.config.mjs) — that file
 * renders the unified nbg-topnav with brand + section links + search +
 * auth + theme toggle + mobile drawer + SignInModal. MarketingShell here
 * is just the page-body wrapper: hero slot, content slot, footer slot.
 *
 * Before 2026-05-19, MarketingShell rendered its own nbg-topnav INSIDE
 * the StarlightPage content (which produced a second navigation bar
 * below Starlight's chrome header). The unified-header refactor moved
 * that markup up into SplashAwareHeader.astro so the marketing surface
 * has exactly one nav bar — the one at the very top.
 *
 * Option-2 escape hatch: an Option-2 escalation (replace Starlight)
 * rewrites THIS file + tokens/aliases.css + SplashAwareHeader.astro +
 * SocialIconsOverride.astro. Everything else (primitives, content
 * collections, lib/, surface pages) survives.
 *
 * Related: project-design.md §S.13.6 (this file's body wrapper),
 *          §S.13.6.1 (the unified header in SplashAwareHeader).
 * Backs: AC31, AC32, AC33, AC36 (Starlight isolation boundary).
 */
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Container from './primitives/Container.astro';
import Section from './primitives/Section.astro';
// §S.14.4 — Glossary tooltip registry. Renders once per marketing page.
// Inlines `<script type="application/json" id="nbg-glossary-data">` plus the
// runtime wiring script that hydrates every `[data-glossary-slug]` button
// emitted by the remark plugin into a popover. Build-time portable (zero
// @astrojs/starlight imports), so it works under any Astro chrome.
import GlossaryTerm from './primitives/GlossaryTerm.astro';
// UAT T10 V1 — toast on pin/unpin success. Mounted once per marketing page;
// any script can `document.dispatchEvent(new CustomEvent('nbgaihub:toast', {detail: {title, action?}}))`.
import Toast from './Toast.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  surfaceId?: string;
  hero?: 'auto' | 'none';
  width?: 'default' | 'wide' | 'full';
  theme?: 'default' | 'inverse';
  /** "reader" applies a calmer, single-rhythm content treatment.
   *  See `[data-mode="reader"]` rules in agentnews-layout.css. Used on
   *  long-scroll content pages (Foundations, Day 1, etc.). */
  mode?: 'default' | 'reader';
}

const {
  title,
  description,
  eyebrow,
  surfaceId,
  hero = 'auto',
  width = 'wide',
  theme = 'default',
  mode = 'default',
} = Astro.props;

// Per global no-fallback rule — `title` is required.
if (!title) {
  throw new Error('MarketingShell requires a `title` prop.');
}

const hasHeroSlot = Astro.slots.has('hero');
const hasFooter   = Astro.slots.has('footer');
const showHero    = hero === 'auto' && hasHeroSlot;
---
<StarlightPage frontmatter={{ template: 'splash', title, description, pagefind: true }}>
  <main
    class="nbg-marketing"
    data-marketing="true"
    data-surface={surfaceId}
    data-theme-mode={theme}
    data-width={width}
    data-mode={mode}
  >
    {eyebrow && (
      <p class="nbg-marketing__eyebrow" data-marketing-eyebrow>{eyebrow}</p>
    )}

    {showHero && (
      <Section spacing="default" tone="default" as="header" surfaceId={surfaceId ? `${surfaceId}-hero` : undefined}>
        <Container width={width}>
          <slot name="hero" />
        </Container>
      </Section>
    )}

    <Container width={width}>
      <slot />
    </Container>

    {hasFooter && (
      <Section spacing="default" tone="subtle" as="footer">
        <Container width={width}>
          <slot name="footer" />
        </Container>
      </Section>
    )}
  </main>

  <GlossaryTerm />
  <Toast />
</StarlightPage>

<script>
  // P4.K — wire the scroll-reveal IntersectionObserver on every marketing
  // page. Astro hoists module-imported `<script>` tags and dedupes them
  // across renders. The module honors prefers-reduced-motion internally.
  import '../scripts/motion.ts';
</script>

<style is:global>
  /* Marketing-page resets — applied at @layer nbg.components so they win over
   * Starlight's defaults without needing !important.
   *
   * (1) Hide Starlight's auto-rendered page <h1> on splash marketing pages —
   *     each surface renders its own Display H1 inside the hero slot, so the
   *     auto title is a duplicate.
   * (2) Hide Starlight's auto prev/next pagination on marketing pages — we
   *     drive navigation through the top-nav, not pager links.
   */
  /* Hide the single auto-rendered Starlight page-title and its wrapping
   * content-panel. Splash template emits
   * `.content-panel > .sl-container > h1#_top` at the top of every page;
   * each marketing surface renders its own Display H1 inside the hero
   * slot, so the auto title is a visual duplicate.
   *
   * Unlayered + !important because Starlight ships its own .content-panel
   * rules inside `@layer starlight.core` with `:where()` (0 specificity).
   * Layer-ordering would otherwise need an explicit @layer order declaration
   * to ensure nbg.components wins; the !important short-circuits that. */
  .content-panel:has(> .sl-container > h1#_top),
  h1#_top {
    display: none !important;
  }

  /* Starlight ships `.content-panel { border-top: 1px solid var(--sl-color-hairline) }`
   * which adds a hairline above every content panel. On marketing surfaces
   * we hide the FIRST content-panel (the auto h1 wrapper, rule above) so
   * the SECOND content-panel's border-top renders just below the sticky
   * bar — producing a visible "doubled hairline" stacked beneath the
   * Starlight header border. Drop all content-panel borders on
   * data-marketing surfaces so only the Starlight header hairline remains. */
  body:has([data-marketing='true']) .content-panel {
    border-top: 0 !important;
  }

  /* Pagination — Starlight auto-builds prev/next from the sidebar order.
   * The top-nav covers this on every marketing surface. */
  .pagination-links {
    display: none !important;
  }

  /* AgentNews vertical-rhythm override (2026-05-24).
   * Starlight's <header> wraps the nbg-topnav with vertical padding
   *   (.header { padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x) })
   * which produces ~12px of extra white space above + below the visible
   * nav content. AgentNews's nav has zero wrapper padding — the nav's
   * own .nbg-topnav__inner controls horizontal padding. We zero out the
   * Starlight wrapper padding on marketing surfaces, and shrink the
   * mobile-toc placeholder. */
  body:has([data-marketing='true']) {
    --sl-nav-pad-y: 0;
    --sl-nav-pad-x: 0;
    --sl-mobile-toc-height: 0;
  }
  /* Topnav inner max-width must match the AgentNews container (1240px)
   * so the brand + nav links align with the .wrap inside each section.
   * `margin-inline: auto` centers the 1240px inner within the viewport-
   * wide outer nav — without it, the inner left-anchors and wide
   * viewports show a big empty gap on the right of the nav bar
   * (visible on 1920px monitors viewing the deployed Pages site). */
  body:has([data-marketing='true']) .nbg-topnav__inner {
    max-width: var(--nbg-container-max, 77.5rem) !important;
    margin-inline: auto !important;
    padding-inline: var(--nbg-container-pad-desktop, 2rem) !important;
  }
  @media (max-width: 45rem) {
    body:has([data-marketing='true']) .nbg-topnav__inner {
      padding-inline: var(--nbg-container-pad-mobile, 1.25rem) !important;
    }
  }

  /* Visible nav/page division (matches AgentNews's .site-header bottom hairline).
   * The topnav background is semi-transparent so when the page hasn't scrolled,
   * nav-bg and hero-bg share the same colour. Add an explicit hairline at the
   * bottom of the topnav AND a tiny shadow for depth — both consume tokens. */
  body:has([data-marketing='true']) .nbg-topnav {
    background: var(--nbg-header-bg, color-mix(in srgb, var(--nbg-bg, var(--nbg-color-bg-canvas)) 85%, transparent)) !important;
    border-bottom: 1px solid var(--nbg-hairline, var(--nbg-color-border-subtle)) !important;
    box-shadow: 0 1px 0 0 var(--nbg-hairline, var(--nbg-color-border-subtle));
  }

  /* AgentNews full-bleed override (2026-05-24).
   * Starlight wraps the marketing body in
   *   <main> > .content-panel > .sl-container > .sl-markdown-content
   * each of which applies a max-width / padding. For AgentNews-style
   * full-bleed layout we drop those constraints on marketing surfaces
   * so the page body can span the viewport and the inner `.wrap` does
   * the centering.
   *
   * Scoped via `body:has([data-marketing='true'])` so content-detail
   * pages (which legitimately want the Starlight content gutter) are
   * untouched. */
  body:has([data-marketing='true']) .content-panel {
    padding: 0 !important;
  }
  body:has([data-marketing='true']) .content-panel > .sl-container,
  body:has([data-marketing='true']) .content-panel > .sl-container > .sl-markdown-content {
    max-width: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  /* Starlight's <main> sets max-width on splash pages too — undo. */
  body:has([data-marketing='true']) .main-pane > main,
  body:has([data-marketing='true']) .main-frame > main {
    max-width: none !important;
  }
  /* The splash template ships .main-pane with a left-side rail width on
   * larger viewports. Drop it on marketing surfaces. */
  body:has([data-marketing='true']) .main-pane {
    max-width: none !important;
    width: 100% !important;
  }
  body:has([data-marketing='true']) .lg\:sl-flex {
    max-width: none !important;
  }
</style>

<style>
  @layer nbg.components {
    .nbg-marketing {
      background: var(--nbg-color-bg-canvas);
      color: var(--nbg-color-fg-primary);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-md);
      line-height: var(--nbg-lh-base);
      min-height: 100%;
    }
    .nbg-marketing[data-theme-mode='inverse'] {
      background: var(--nbg-color-bg-elevated);
    }
    .nbg-marketing__eyebrow {
      margin: 0;
      padding-block: var(--nbg-sp-4);
      text-align: center;
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-xs);
      letter-spacing: var(--nbg-ls-wide);
      text-transform: uppercase;
      color: var(--nbg-color-fg-muted);
    }
  }
</style>
