---
// site/src/components/SignInModal.astro
//
// Global sign-in dialog. Single instance is mounted by SocialIconsOverride.astro
// so it ships with the header on every page. Opens in response to a
// `nbgaihub:open-signin-modal` custom event dispatched by:
//   - the header's Sign in button
//   - PinButton (when a signed-out user clicks a per-row pin)
//
// 2026-05-25 late-night UAT redesign:
//   - Centered positioning (previously pinned top-left even with showModal)
//   - Serif title + eyebrow matching the homepage / Foundations hero pattern
//   - Two-step layout: STEP 1 "Create a token on GitHub" → STEP 2 "Paste it here"
//   - Token input gets a leading lock glyph + monospace value
//   - "Sign in" primary CTA (was "Validate & sign in" — devspeak)
//   - Backdrop is a softer overlay; dialog has a generous radius + shadow
//
// All data-nbg-signin-* hooks + the script block at the bottom are preserved
// bit-for-bit so the auth flow is untouched.
---

<dialog
  class="nbg-signin"
  data-nbg-signin-dialog
  aria-labelledby="nbg-signin-title"
>
  <form method="dialog" class="nbg-signin__form" data-nbg-signin-form novalidate>
    <button
      type="button"
      class="nbg-signin__close"
      data-nbg-signin-close
      aria-label="Close"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>

    <header class="nbg-signin__header">
      <p class="nbg-signin__eyebrow">Sign in</p>
      <h2 id="nbg-signin-title" class="nbg-signin__title">
        Pin what you want to come <em>back to</em>.
      </h2>
      <p class="nbg-signin__lede">
        Your pins live in your own unlisted GitHub gist — not on our server, not shared
        with the team. Sign in with a Personal Access Token to start pinning.
      </p>
    </header>

    <ol class="nbg-signin__steps">
      <li class="nbg-signin__step">
        <span class="nbg-signin__step-num">01</span>
        <div class="nbg-signin__step-body">
          <p class="nbg-signin__step-title">Create a token on GitHub</p>
          <p class="nbg-signin__step-hint">
            Scope: <code>gist</code> only. Nothing else. Takes 30 seconds.
          </p>

          {/* UAT T13 V1 (2026-05-27) — inline visual cue of the GitHub token
              page. Recognition over recall: the reader sees what's behind the
              deeplink before they leave the hub. Built as a static
              CSS/HTML mock for now; a real captured screenshot can replace
              it later (see Issues - Pending Items). */}
          <figure class="nbg-signin__preview" aria-hidden="true">
            <div class="nbg-signin__preview-bar">
              <span class="nbg-signin__preview-dot"></span>
              <span class="nbg-signin__preview-dot"></span>
              <span class="nbg-signin__preview-dot"></span>
              <span class="nbg-signin__preview-url">github.com/settings/tokens/new</span>
            </div>
            <div class="nbg-signin__preview-body">
              <p class="nbg-signin__preview-title">New personal access token</p>
              <div class="nbg-signin__preview-field">
                <label>Note</label>
                <div class="nbg-signin__preview-input nbg-signin__preview-input--filled">NbgAiHub</div>
                <span class="nbg-signin__preview-callout">1</span>
              </div>
              <div class="nbg-signin__preview-field">
                <label>Expiration</label>
                <div class="nbg-signin__preview-input">your choice — 30 days is a good default</div>
              </div>
              <div class="nbg-signin__preview-field">
                <label>Select scopes</label>
                <div class="nbg-signin__preview-checks">
                  <span class="nbg-signin__preview-check nbg-signin__preview-check--on">
                    <span class="nbg-signin__preview-check-mark"></span>
                    gist
                  </span>
                  <span class="nbg-signin__preview-callout">2</span>
                  <span class="nbg-signin__preview-check">repo</span>
                  <span class="nbg-signin__preview-check">workflow</span>
                  <span class="nbg-signin__preview-check">…</span>
                </div>
              </div>
              <div class="nbg-signin__preview-cta">
                <span class="nbg-signin__preview-btn">Generate token</span>
                <span class="nbg-signin__preview-callout">3</span>
              </div>
            </div>
            <figcaption class="nbg-signin__preview-caption">
              <strong>1</strong> Name it <code>NbgAiHub</code>. <strong>2</strong> Tick <code>gist</code> only. <strong>3</strong> Click Generate, copy the token.
            </figcaption>
          </figure>

          <a
            class="nbg-signin__deeplink"
            href="https://github.com/settings/tokens/new?scopes=gist&description=NbgAiHub"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open GitHub token page
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7M7 7h10v10" />
            </svg>
          </a>
        </div>
      </li>

      <li class="nbg-signin__step">
        <span class="nbg-signin__step-num">02</span>
        <div class="nbg-signin__step-body">
          <label class="nbg-signin__step-title" for="nbg-signin-token">
            Paste the token here
          </label>
          <p class="nbg-signin__step-hint">
            Stored only in this browser's localStorage. Sent only to api.github.com.
          </p>
          <div class="nbg-signin__input-wrap">
            <svg class="nbg-signin__input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <input
              id="nbg-signin-token"
              class="nbg-signin__input"
              data-nbg-signin-input
              type="password"
              autocomplete="off"
              spellcheck="false"
              placeholder="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
              required
            />
          </div>
        </div>
      </li>
    </ol>

    <p class="nbg-signin__error" data-nbg-signin-error role="alert" hidden></p>

    <div class="nbg-signin__actions">
      <button
        type="button"
        class="nbg-signin__btn nbg-signin__btn--secondary"
        data-nbg-signin-cancel
      >
        Cancel
      </button>
      <button
        type="submit"
        class="nbg-signin__btn nbg-signin__btn--primary"
        data-nbg-signin-submit
      >
        Sign in
      </button>
    </div>
  </form>
</dialog>

<style>
  @layer nbg.components {
    /* ─── Dialog chrome ─────────────────────────────────────────────── */
    .nbg-signin {
      /* Centered via fixed positioning. UA default for <dialog open> is
       * `position: absolute` pinned to the document origin, which renders
       * the modal at top-left. Explicit centering works for both showModal()
       * and the fallback `setAttribute('open','')` path. */
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      margin: 0;

      border: 1px solid var(--nbg-border, #dce3eb);
      border-radius: 16px;
      padding: 0;
      background: var(--nbg-surface, #ffffff);
      color: var(--nbg-ink, #0b1e2e);
      max-width: 30rem;
      width: calc(100% - 2rem);
      box-shadow:
        0 24px 60px rgba(11, 30, 46, 0.18),
        0 8px 24px rgba(11, 30, 46, 0.10);
      overflow: visible;
    }
    .nbg-signin::backdrop {
      background: rgba(11, 30, 46, 0.55);
      backdrop-filter: blur(6px);
    }
    /* Fallback for browsers that don't apply ::backdrop styles when the
     * dialog is opened via the `open` attribute rather than showModal(). */
    .nbg-signin[open] {
      animation: nbg-signin-enter 180ms ease-out;
    }
    @keyframes nbg-signin-enter {
      from { opacity: 0; transform: translate(-50%, -48%); }
      to   { opacity: 1; transform: translate(-50%, -50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .nbg-signin[open] { animation: none; }
    }

    /* ─── Form layout ───────────────────────────────────────────────── */
    .nbg-signin__form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      padding: 2rem 1.75rem 1.5rem;
      position: relative;
    }

    .nbg-signin__close {
      position: absolute;
      top: 0.85rem;
      right: 0.85rem;
      background: transparent;
      border: 0;
      color: var(--nbg-muted, #5b6b80);
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      cursor: pointer;
      transition:
        background-color 120ms ease,
        color            120ms ease;
    }
    .nbg-signin__close:hover {
      background: var(--nbg-surface-2, #f8fafc);
      color: var(--nbg-ink, #0b1e2e);
    }
    .nbg-signin__close:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* ─── Header — matches homepage hero typography ──────────────────── */
    .nbg-signin__header {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding-right: 2.5rem; /* room for the close button */
    }
    .nbg-signin__eyebrow {
      margin: 0;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--nbg-accent, #007a8a);
    }
    .nbg-signin__title {
      margin: 0;
      font-family: var(--nbg-ff-serif, 'Newsreader', Georgia, serif);
      font-size: 1.625rem;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--nbg-ink, #0b1e2e);
    }
    .nbg-signin__title em {
      font-style: italic;
      color: var(--nbg-accent, #007a8a);
    }
    .nbg-signin__lede {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.55;
      color: var(--nbg-muted, #5b6b80);
    }

    /* ─── Numbered step list ────────────────────────────────────────── */
    .nbg-signin__steps {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 1rem;
      counter-reset: nbg-signin-step;
    }
    .nbg-signin__step {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.85rem;
      align-items: start;
      padding: 1rem;
      background: var(--nbg-surface-2, #f8fafc);
      border: 1px solid var(--nbg-hairline, #ebeff5);
      border-radius: 10px;
    }
    .nbg-signin__step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 6px;
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      line-height: 1;
    }
    .nbg-signin__step-body {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      min-width: 0;
    }
    .nbg-signin__step-title {
      margin: 0;
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--nbg-ink, #0b1e2e);
      line-height: 1.3;
      display: block;
    }
    .nbg-signin__step-hint {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.5;
      color: var(--nbg-muted, #5b6b80);
    }
    .nbg-signin__step-hint code {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.875em;
      padding: 0.05em 0.35em;
      background: var(--nbg-surface, #ffffff);
      border: 1px solid var(--nbg-hairline, #ebeff5);
      border-radius: 4px;
      color: var(--nbg-accent-ink, #00525c);
    }

    .nbg-signin__deeplink {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.25rem;
      padding: 0.5rem 0.8rem;
      background: var(--nbg-surface, #ffffff);
      color: var(--nbg-accent, #007a8a);
      text-decoration: none;
      border: 1px solid var(--nbg-border, #dce3eb);
      border-radius: 8px;
      font-family: var(--nbg-ff-body);
      font-size: 0.8125rem;
      font-weight: 600;
      width: fit-content;
      transition:
        border-color 120ms ease,
        background-color 120ms ease,
        color 120ms ease;
    }
    .nbg-signin__deeplink:hover {
      border-color: var(--nbg-accent, #007a8a);
      background: var(--nbg-accent-soft, #e0f2f4);
      color: var(--nbg-accent-ink, #00525c);
    }
    .nbg-signin__deeplink:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* UAT T13 V1 — inline visual cue of the GitHub token-creation page.
       A CSS mock for now; can be swapped for a real captured screenshot
       once an operator (or someone logged into github.com) captures one. */
    .nbg-signin__preview {
      margin: 0.85rem 0;
      border: 1px solid var(--nbg-border, #dce3eb);
      border-radius: 8px;
      overflow: hidden;
      background: var(--nbg-surface, #ffffff);
      font-size: 0.75rem;
      line-height: 1.4;
    }
    .nbg-signin__preview-bar {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.6rem;
      border-bottom: 1px solid var(--nbg-border, #dce3eb);
      background: var(--nbg-surface-2, #f4f6fa);
    }
    .nbg-signin__preview-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--nbg-muted-2, #8392a6);
      opacity: 0.5;
    }
    .nbg-signin__preview-url {
      margin-left: 0.4rem;
      font-family: var(--nbg-ff-mono);
      font-size: 0.7rem;
      color: var(--nbg-muted, #5b6b80);
    }
    .nbg-signin__preview-body {
      padding: 0.7rem 0.85rem;
      display: grid;
      gap: 0.55rem;
    }
    .nbg-signin__preview-title {
      margin: 0 0 0.15rem 0;
      font-weight: 600;
      color: var(--nbg-ink, #0b1e2e);
      font-size: 0.825rem;
    }
    .nbg-signin__preview-field {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      position: relative;
    }
    .nbg-signin__preview-field label {
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--nbg-muted, #5b6b80);
      font-weight: 600;
    }
    .nbg-signin__preview-input {
      padding: 0.35rem 0.55rem;
      border: 1px solid var(--nbg-border, #dce3eb);
      border-radius: 4px;
      background: var(--nbg-surface-2, #f4f6fa);
      color: var(--nbg-muted, #5b6b80);
      font-family: var(--nbg-ff-mono);
    }
    .nbg-signin__preview-input--filled {
      background: var(--nbg-surface, #ffffff);
      color: var(--nbg-ink, #0b1e2e);
      border-color: var(--nbg-accent, #007a8a);
    }
    .nbg-signin__preview-checks {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      align-items: center;
    }
    .nbg-signin__preview-check {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--nbg-surface-2, #f4f6fa);
      color: var(--nbg-muted, #5b6b80);
      font-family: var(--nbg-ff-mono);
      font-size: 0.72rem;
    }
    .nbg-signin__preview-check--on {
      background: color-mix(in srgb, var(--nbg-accent, #007a8a) 14%, transparent);
      color: var(--nbg-accent-ink, var(--nbg-accent, #007a8a));
      border: 1px solid var(--nbg-accent, #007a8a);
    }
    .nbg-signin__preview-check-mark {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      background: var(--nbg-accent, #007a8a);
    }
    .nbg-signin__preview-cta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.25rem;
    }
    .nbg-signin__preview-btn {
      display: inline-block;
      padding: 0.35rem 0.7rem;
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.75rem;
    }
    .nbg-signin__preview-callout {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      font-size: 0.65rem;
      font-weight: 700;
      font-family: var(--nbg-ff-mono);
      margin-left: 0.4rem;
      flex-shrink: 0;
    }
    .nbg-signin__preview-field .nbg-signin__preview-callout,
    .nbg-signin__preview-checks .nbg-signin__preview-callout {
      position: absolute;
      right: 0;
      top: 1.2rem;
    }
    .nbg-signin__preview-checks .nbg-signin__preview-callout {
      position: static;
    }
    .nbg-signin__preview-caption {
      padding: 0.55rem 0.85rem;
      border-top: 1px solid var(--nbg-border, #dce3eb);
      background: var(--nbg-surface-2, #f4f6fa);
      color: var(--nbg-muted, #5b6b80);
      font-size: 0.72rem;
      line-height: 1.5;
    }
    .nbg-signin__preview-caption strong {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      font-size: 0.65rem;
      font-weight: 700;
      margin: 0 0.2rem 0 0.35rem;
      vertical-align: 1px;
    }
    .nbg-signin__preview-caption strong:first-child {
      margin-left: 0;
    }

    /* ─── Token input ────────────────────────────────────────────────── */
    .nbg-signin__input-wrap {
      position: relative;
      display: flex;
      align-items: center;
      margin-top: 0.25rem;
    }
    .nbg-signin__input-icon {
      position: absolute;
      left: 0.7rem;
      color: var(--nbg-muted, #5b6b80);
      pointer-events: none;
    }
    .nbg-signin__input {
      width: 100%;
      padding: 0.6rem 0.75rem 0.6rem 2.2rem;
      border: 1px solid var(--nbg-border, #dce3eb);
      border-radius: 8px;
      background: var(--nbg-surface, #ffffff);
      color: var(--nbg-ink, #0b1e2e);
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.8125rem;
      letter-spacing: 0.02em;
      transition:
        border-color 120ms ease,
        box-shadow   120ms ease;
    }
    .nbg-signin__input::placeholder {
      color: var(--nbg-muted-2, #8392a6);
      letter-spacing: 0;
    }
    .nbg-signin__input:focus-visible {
      outline: none;
      border-color: var(--nbg-accent, #007a8a);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--nbg-accent, #007a8a) 18%, transparent);
    }

    /* ─── Error ──────────────────────────────────────────────────────── */
    .nbg-signin__error {
      margin: 0;
      padding: 0.6rem 0.85rem;
      border-radius: 8px;
      background: var(--nbg-color-status-danger-bg, #fff1f2);
      color: var(--nbg-color-status-danger-fg, #be123c);
      font-size: 0.875rem;
      line-height: 1.4;
      border: 1px solid color-mix(in srgb, var(--nbg-color-status-danger-fg, #be123c) 30%, transparent);
    }

    /* ─── Actions ────────────────────────────────────────────────────── */
    .nbg-signin__actions {
      display: flex;
      gap: 0.6rem;
      justify-content: flex-end;
      margin-top: 0.25rem;
    }
    .nbg-signin__btn {
      padding: 0.55rem 1.1rem;
      border-radius: 8px;
      font-family: var(--nbg-ff-body);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid var(--nbg-border, #dce3eb);
      transition:
        background-color 120ms ease,
        border-color     120ms ease,
        color            120ms ease,
        box-shadow       120ms ease;
    }
    .nbg-signin__btn:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
    .nbg-signin__btn--primary {
      background: var(--nbg-accent, #007a8a);
      color: #ffffff;
      border-color: var(--nbg-accent, #007a8a);
    }
    .nbg-signin__btn--primary:hover:not(:disabled) {
      background: var(--nbg-accent-ink, #00525c);
      border-color: var(--nbg-accent-ink, #00525c);
    }
    .nbg-signin__btn--primary:disabled {
      opacity: 0.6;
      cursor: progress;
    }
    .nbg-signin__btn--secondary {
      background: transparent;
      color: var(--nbg-muted, #5b6b80);
    }
    .nbg-signin__btn--secondary:hover:not(:disabled) {
      background: var(--nbg-surface-2, #f8fafc);
      color: var(--nbg-ink, #0b1e2e);
      border-color: var(--nbg-muted, #5b6b80);
    }

    /* ─── Mobile ─────────────────────────────────────────────────────── */
    @media (max-width: 480px) {
      .nbg-signin {
        max-width: none;
        width: calc(100% - 1.5rem);
      }
      .nbg-signin__form {
        padding: 1.5rem 1.25rem 1.25rem;
      }
      .nbg-signin__title {
        font-size: 1.375rem;
      }
    }
  }
</style>

<script>
  // Bundled by Vite as a client module — import from the auth lib works here.
  import { signIn } from '../lib/auth.ts';
  import { TokenInvalidError } from '../lib/api-fetch.ts';

  type Refs = {
    dialog: HTMLDialogElement;
    form: HTMLFormElement;
    input: HTMLInputElement;
    error: HTMLElement;
    submit: HTMLButtonElement;
    closeBtn: HTMLButtonElement;
    cancelBtn: HTMLButtonElement;
  };

  function collect(): Refs | null {
    const dialog = document.querySelector<HTMLDialogElement>('[data-nbg-signin-dialog]');
    const form = document.querySelector<HTMLFormElement>('[data-nbg-signin-form]');
    const input = document.querySelector<HTMLInputElement>('[data-nbg-signin-input]');
    const error = document.querySelector<HTMLElement>('[data-nbg-signin-error]');
    const submit = document.querySelector<HTMLButtonElement>('[data-nbg-signin-submit]');
    const closeBtn = document.querySelector<HTMLButtonElement>('[data-nbg-signin-close]');
    const cancelBtn = document.querySelector<HTMLButtonElement>('[data-nbg-signin-cancel]');
    if (!dialog || !form || !input || !error || !submit || !closeBtn || !cancelBtn) {
      return null;
    }
    return { dialog, form, input, error, submit, closeBtn, cancelBtn };
  }

  function showError(refs: Refs, msg: string): void {
    refs.error.textContent = msg;
    refs.error.hidden = false;
  }

  function clearError(refs: Refs): void {
    refs.error.textContent = '';
    refs.error.hidden = true;
  }

  function close(refs: Refs): void {
    if (refs.dialog.open) refs.dialog.close();
    refs.input.value = '';
    clearError(refs);
    refs.submit.disabled = false;
  }

  function open(refs: Refs): void {
    clearError(refs);
    refs.input.value = '';
    refs.submit.disabled = false;
    // Native <dialog> handles focus + Esc-to-close on showModal().
    if (typeof refs.dialog.showModal === 'function') {
      refs.dialog.showModal();
    } else {
      // Old browser fallback — just toggle the `open` attribute.
      refs.dialog.setAttribute('open', '');
    }
    // Defer focus until after the dialog is on-screen.
    queueMicrotask(() => refs.input.focus());
  }

  async function onSubmit(refs: Refs, event: Event): Promise<void> {
    event.preventDefault();
    clearError(refs);
    const token = refs.input.value.trim();
    if (token === '') {
      showError(refs, 'Please paste your token.');
      return;
    }
    refs.submit.disabled = true;
    try {
      await signIn(token);
      close(refs);
      // Subscribers (e.g. SocialIconsOverride) re-render via auth.subscribe();
      // reload still helps any per-page personalization that doesn't subscribe.
      window.location.reload();
    } catch (err) {
      refs.submit.disabled = false;
      if (err instanceof TokenInvalidError) {
        showError(refs, 'Invalid token. Check the value and the `gist` scope.');
      } else {
        const msg = err instanceof Error ? err.message : String(err);
        showError(refs, `Network error: ${msg}`);
      }
    }
  }

  function init(): void {
    const refs = collect();
    if (!refs) return;

    document.addEventListener('nbgaihub:open-signin-modal', () => open(refs));

    refs.form.addEventListener('submit', (e) => {
      void onSubmit(refs, e);
    });

    refs.closeBtn.addEventListener('click', () => close(refs));
    refs.cancelBtn.addEventListener('click', () => close(refs));

    // Clicking on the backdrop closes the dialog.
    refs.dialog.addEventListener('click', (event) => {
      if (event.target === refs.dialog) close(refs);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
