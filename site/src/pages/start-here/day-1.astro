---
/**
 * /start-here/day-1 — AgentNews-aesthetic Day-1 onboarding journey.
 *
 * Preserves the existing markdown-segmentation + step-rendering logic
 * (Astro markdown processor, `## Step N — Title` split, server-side HTML
 * injection). Chrome is migrated to AgentNews .hero + .section + .wrap.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #10.
 * Backs AC10, AC15.
 */
import { getEntry, getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import MarketingShell from '../../components/MarketingShell.astro';
import TerminalDemo from '../../components/TerminalDemo.astro';
import type { TerminalFrame } from '../../components/TerminalDemo.astro';
import remarkGlossaryLink from '../../plugins/remark-glossary-link.ts';
import { linkGlossaryTerms } from '../../lib/glossary-link-string';

// UAT T19 V2 (2026-05-27) — annotated visuals slotted into Day 1 Steps 3 + 4.
// CSS-styled terminal blocks for now; real captures (PNGs or asciinema) can
// replace these slots later. Bound to step numbers so they survive the
// 2026-05-27 step renumber (Step 3 = first session; Step 4 = survival keys).
const firstSessionFrames: TerminalFrame[] = [
  {
    prompt: 'cd NbgAiHub',
    response: '/Users/suzy/projects/NbgAiHub',
    callout: { n: 1, note: 'Move into the project folder. Claude only sees files in here.' },
  },
  {
    prompt: 'claude --dangerously-skip-permissions',
    response: 'Reading CLAUDE.md … Ready. What would you like to do?',
    callout: { n: 2, note: 'Claude reads CLAUDE.md and waits for your first prompt.' },
  },
  {
    prompt: "what's in this repo? short answer please",
    response: 'A curated Claude Code knowledge hub. Astro static site, glossary, tips, skills, and a Day-1 walkthrough.',
    callout: { n: 3, note: 'Plain-language questions work. No code required to start.' },
  },
];
const survivalKeysFrames: TerminalFrame[] = [
  {
    prompt: 'find every Python file and convert to TypeScript',
    response: 'Found 142 .py files. Beginning conversion…\n  src/a.py → src/a.ts\n  src/b.py → src/b.ts\n  …',
    callout: { n: 1, note: "Claude misread the task. Press Esc once — it stops immediately." },
  },
  {
    response: '⎯ Aborted. Press Esc Esc to rewind the conversation, or type a new instruction.',
    callout: { n: 2, note: 'Esc Esc opens a session-history scrubber to walk back several steps.' },
  },
  {
    prompt: '/compact',
    response: 'Summarising the conversation so far … done. Active context: ~3.1k tokens.',
    callout: { n: 3, note: '/compact summarises a long session without losing the thread. /clear wipes it.' },
  },
];

// UAT T15 V2 — read glossary length at build time so the count never
// drifts away from Foundations (was "Thirty-four" while Foundations
// said "Thirty-six").
const glossaryCount = (await getCollection('glossary')).length;

const entry = await getEntry('journeys', 'day-1');
if (!entry) {
  throw new Error(
    "Missing journeys collection entry 'day-1' — expected at /journeys/day-1.md",
  );
}

const rawBody: string | undefined = entry.body;
if (typeof rawBody !== 'string' || rawBody.trim().length === 0) {
  throw new Error(
    "journeys/day-1.md has an empty body — expected `## Step N` segmented content.",
  );
}

interface ParsedStep {
  n: number;
  title: string;
  bodyMd: string;
}

function splitSteps(body: string): { intro: string; steps: ParsedStep[] } {
  const lines = body.split('\n');
  const headingRe = /^##\s+Step\s+(\d+)\s*[—\-]\s*(.+?)\s*$/;

  const introLines: string[] = [];
  const steps: ParsedStep[] = [];
  let current: ParsedStep | null = null;

  for (const line of lines) {
    const match = line.match(headingRe);
    if (match && match[1] && match[2]) {
      if (current) steps.push(current);
      current = { n: Number.parseInt(match[1], 10), title: match[2], bodyMd: '' };
      continue;
    }
    if (current) {
      current.bodyMd += (current.bodyMd ? '\n' : '') + line;
    } else {
      introLines.push(line);
    }
  }
  if (current) steps.push(current);

  for (const step of steps) {
    step.bodyMd = step.bodyMd.replace(/\n---\s*\n?\s*$/, '\n').trim();
  }

  return { intro: introLines.join('\n').trim(), steps };
}

const { intro, steps } = splitSteps(rawBody);

if (steps.length === 0) {
  throw new Error(
    "journeys/day-1.md contains no `## Step N` headings — Day-1 layout requires step segmentation.",
  );
}

// §S.14.5 — pass the glossary auto-link plugin into the manual processor
// so segmented steps go through the same auto-linking pipeline as the
// content-collection render() path. Cast is needed because
// `createMarkdownProcessor`'s `remarkPlugins` is typed against unified's
// generic Plugin shape, while our factory returns the narrower
// `Plugin<[], Root, Root>` — the runtime contract is identical.
const processor = await createMarkdownProcessor({
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  remarkPlugins: [
    [
      remarkGlossaryLink as any,
      { glossaryDir: '../glossary', excludePaths: ['/news/published/'] },
    ],
  ],
});

const renderedSteps = await Promise.all(
  steps.map(async (step) => {
    const result = await processor.render(step.bodyMd);
    return { ...step, html: result.code };
  }),
);

const introHtml = intro.length > 0 ? (await processor.render(intro)).code : '';

const heroTitle = entry.data.title ?? 'Day 1';
const heroSummary = entry.data.ai_summary;
---

<MarketingShell
  title={heroTitle}
  description={heroSummary}
  surfaceId="day-1"
  width="full"
  hero="none"
  mode="reader"
>
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Where to start, <em>practically</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms(heroSummary)} />
          <small>Audience: {entry.data.audience} · ~30 min · {renderedSteps.length} steps</small>
        </p>
      </div>
      <nav class="journey-overview" aria-label="Day 1 steps">
        <ol>
          {renderedSteps.map((step) => (
            <li>
              <a href={`#step-${step.n}`} data-step-id={`step-${step.n}`}>
                <span class="journey-overview__num">{String(step.n).padStart(2, '0')}</span>
                <span class="journey-overview__label" set:html={step.title.replace(/`([^`]+)`/g, '<code>$1</code>')} />
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  {introHtml.length > 0 && (
    <section class="section" id="intro" style="padding-block: 2rem;">
      <div class="wrap">
        <div class="journey-intro sl-markdown-content" set:html={introHtml} />
      </div>
    </section>
  )}

  {renderedSteps.map((step) => (
    <section
      class="section"
      id={`step-${step.n}`}
      data-step={step.n}
      aria-label={`Step ${step.n}: ${step.title}`}
    >
      <div class="wrap">
        <div class="section__head">
          <h2>Step {step.n} / {renderedSteps.length}</h2>
          <span class="count">{step.title}</span>
        </div>
        <div class="journey-step">
          <div class="journey-step__header">
            <span class="journey-step__badge" aria-hidden="true">{String(step.n).padStart(2, '0')}</span>
            <h3 class="journey-step__title" set:html={step.title.replace(/`([^`]+)`/g, '<code>$1</code>')} />
          </div>
          <div class="journey-step__body sl-markdown-content" set:html={step.html} />
          {/* UAT T19 V2 — visual peek slotted at the steps where seeing the
              UI most reduces anxiety: Step 3 (first session) and Step 4
              (survival keys). Bound to step.n so a future reorder doesn't
              silently disconnect them from their content. */}
          {step.n === 3 && (
            <TerminalDemo
              title="Your first session"
              frames={firstSessionFrames}
              caption="Stylised preview. A real recording will replace this slot."
            />
          )}
          {step.n === 4 && (
            <TerminalDemo
              title="Esc, Esc Esc, /compact, /clear"
              frames={survivalKeysFrames}
              caption="Stylised preview. A real recording will replace this slot."
            />
          )}
        </div>
      </div>
    </section>
  ))}

  <section class="section" id="next">
    <div class="wrap">
      <div class="section__head">
        <h2>Where next</h2>
      </div>
      <div class="grid-2">
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta"><span class="eyebrow eyebrow--accent">Tips</span></div>
            <h3 class="card__title"><a href="/tips/">Tips &amp; tricks</a></h3>
            <p class="card__summary" set:html={linkGlossaryTerms('Prompting patterns, survival keys, context discipline — the small habits that compound.')} />
          </div>
        </article>
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta"><span class="eyebrow eyebrow--accent">Glossary</span></div>
            <h3 class="card__title"><a href="/glossary/">Look up terms</a></h3>
            <p class="card__summary" set:html={linkGlossaryTerms(`${glossaryCount} terms in plain English — what they mean, when they matter. Use it as a reference, not a reading list.`)} />
          </div>
        </article>
      </div>
    </div>
  </section>
</MarketingShell>

<style>
  @layer nbg.components {
    .journey-intro {
      color: var(--nbg-ink-2);
      font-size: 1.125rem;
      line-height: 1.7;
    }
    .journey-intro :global(p) {
      margin: 0 0 1rem 0;
    }

    /* ── Hero journey overview ────────────────────────────────────────
       A horizontal map of the 5 steps shown directly under the hero
       lede. Lets a newcomer see the whole journey at a glance and jump
       in mid-way on a return visit. Each step renders as a chip with a
       monospaced 0N number and the step title. Active step (when the
       user is scrolled into it) gets accent treatment via JS below. */
    .journey-overview {
      margin-top: 2rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--nbg-hairline);
    }
    .journey-overview ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .journey-overview li {
      margin: 0;
    }
    .journey-overview a {
      display: flex;
      align-items: flex-start;
      gap: 0.625rem;
      padding: 0.875rem 0.875rem 1rem;
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-surface);
      color: var(--nbg-ink-2);
      text-decoration: none;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
      height: 100%;
    }
    .journey-overview a:hover {
      border-color: color-mix(in srgb, var(--nbg-accent) 50%, var(--nbg-hairline));
      background: color-mix(in srgb, var(--nbg-accent) 4%, var(--nbg-surface));
      transform: translateY(-1px);
    }
    .journey-overview a:focus-visible {
      outline: 2px solid var(--nbg-accent);
      outline-offset: 2px;
    }
    .journey-overview li[data-current='true'] a {
      border-color: var(--nbg-accent);
      background: color-mix(in srgb, var(--nbg-accent) 8%, var(--nbg-surface));
    }
    .journey-overview__num {
      font-family: var(--nbg-ff-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      color: var(--nbg-accent);
      font-weight: 600;
      padding-top: 0.1rem;
      flex: 0 0 auto;
    }
    .journey-overview__label {
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      line-height: 1.3;
      color: var(--nbg-ink);
      letter-spacing: -0.005em;
    }
    .journey-overview__label :global(code) {
      font-family: var(--nbg-ff-mono);
      font-size: 0.875em;
      background: var(--nbg-surface-2);
      padding: 0.05em 0.3em;
      border-radius: var(--nbg-r-sm);
    }
    @media (max-width: 60rem) {
      .journey-overview ol {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 36rem) {
      .journey-overview ol {
        grid-template-columns: 1fr;
        gap: 0.5rem;
      }
      .journey-overview a {
        padding: 0.75rem 0.875rem;
      }
    }

    .journey-step {
      max-width: 56rem;
      scroll-margin-top: 5rem;
    }
    .journey-step__header {
      display: flex;
      align-items: baseline;
      gap: 1.25rem;
      margin: 0 0 1.25rem 0;
    }
    .journey-step__badge {
      font-family: var(--nbg-ff-mono);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--nbg-accent);
      flex: 0 0 auto;
      padding: 0.2rem 0.55rem;
      border: 1px solid color-mix(in srgb, var(--nbg-accent) 35%, var(--nbg-hairline));
      border-radius: var(--nbg-r-pill);
      background: color-mix(in srgb, var(--nbg-accent) 6%, transparent);
      line-height: 1.4;
      align-self: center;
    }
    .journey-step__title {
      font-family: var(--nbg-ff-serif);
      font-weight: 500;
      font-size: var(--nbg-fs-feature);
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--nbg-ink);
      margin: 0;
    }
    .journey-step__body {
      color: var(--nbg-ink);
      font-size: 1rem;
      line-height: 1.7;
    }
    .journey-step__body :global(p) {
      margin: 0 0 1rem 0;
    }
    .journey-step__body :global(p:last-child) {
      margin-bottom: 0;
    }
    .journey-step__body :global(ul),
    .journey-step__body :global(ol) {
      margin: 0 0 1rem 0;
      padding-left: 1.5rem;
    }
    .journey-step__body :global(li) {
      margin-bottom: 0.5rem;
    }
    .journey-step__body :global(code) {
      font-family: var(--nbg-ff-mono);
      font-size: 0.95em;
      background: var(--nbg-surface-2);
      padding: 0.1em 0.35em;
      border-radius: var(--nbg-r-sm);
    }
    .journey-step__body :global(pre) {
      background: var(--nbg-surface-2);
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-md);
      padding: 1rem;
      overflow-x: auto;
    }
  }
</style>

<script>
  // Highlight the active step in the hero overview as the user scrolls.
  // Cheap IntersectionObserver — no scroll handler, no requestAnimationFrame.
  // Mirrors the StepIndicator primitive but inline so the page stays self-contained.
  (() => {
    const overview = document.querySelector<HTMLElement>('.journey-overview');
    if (!overview) return;
    const items = overview.querySelectorAll<HTMLElement>('li');
    if (items.length === 0) return;

    const sections: HTMLElement[] = [];
    items.forEach((li) => {
      const link = li.querySelector<HTMLAnchorElement>('a[data-step-id]');
      const id = link?.dataset.stepId;
      if (!id) return;
      const section = document.getElementById(id);
      if (section) sections.push(section);
    });
    if (sections.length === 0) return;

    const setCurrent = (id: string | null) => {
      items.forEach((li) => {
        const a = li.querySelector<HTMLAnchorElement>('a[data-step-id]');
        const isCurrent = a?.dataset.stepId === id;
        li.dataset.current = isCurrent ? 'true' : 'false';
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) setCurrent(visible.target.id);
      },
      { rootMargin: '-25% 0px -55% 0px', threshold: [0, 0.1, 0.5] },
    );
    sections.forEach((s) => observer.observe(s));
  })();
</script>
