---
/**
 * /start-here/day-1 — docs-style scrollable layout (2026-05-27 redesign).
 *
 * Keeps the existing top 5-card `.journey-overview` (per UAT preference) and
 * adds a Foundations-style two-column main: 240px sticky TOC sidebar | main
 * scrollable column. Each step renders as a `.day-section` with a clean
 * title-only header — no "Step X / N" counter, no eyebrow. Body prose is
 * 48rem justified with hyphens.
 *
 * Cascade traps handled:
 *   - Starlight's unlayered `.sl-markdown-content h2` rule is beaten by a
 *     compound selector + !important on `.day-section .day-section__title`.
 *   - `[data-mode="reader"] .foundation-step { max-width: 56rem }` is sidestepped
 *     by using a unique class (`.day-section__prose`) instead.
 */
import { getEntry, getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import MarketingShell from '../../components/MarketingShell.astro';
import remarkGlossaryLink from '../../plugins/remark-glossary-link.ts';
import { linkGlossaryTerms } from '../../lib/glossary-link-string';

const glossaryCount = (await getCollection('glossary')).length;

const entry = await getEntry('journeys', 'day-1');
if (!entry) {
  throw new Error(
    "Missing journeys collection entry 'day-1' — expected at /journeys/day-1.md",
  );
}

const rawBody: string | undefined = entry.body;
if (typeof rawBody !== 'string' || rawBody.trim().length === 0) {
  throw new Error(
    "journeys/day-1.md has an empty body — expected `## Step N` segmented content.",
  );
}

interface ParsedStep {
  n: number;
  title: string;
  bodyMd: string;
}

function splitSteps(body: string): { intro: string; steps: ParsedStep[] } {
  const lines = body.split('\n');
  const headingRe = /^##\s+Step\s+(\d+)\s*[—\-]\s*(.+?)\s*$/;
  const introLines: string[] = [];
  const steps: ParsedStep[] = [];
  let current: ParsedStep | null = null;
  for (const line of lines) {
    const match = line.match(headingRe);
    if (match && match[1] && match[2]) {
      if (current) steps.push(current);
      current = { n: Number.parseInt(match[1], 10), title: match[2], bodyMd: '' };
      continue;
    }
    if (current) {
      current.bodyMd += (current.bodyMd ? '\n' : '') + line;
    } else {
      introLines.push(line);
    }
  }
  if (current) steps.push(current);
  for (const step of steps) {
    step.bodyMd = step.bodyMd.replace(/\n---\s*\n?\s*$/, '\n').trim();
  }
  return { intro: introLines.join('\n').trim(), steps };
}

const { intro, steps } = splitSteps(rawBody);

if (steps.length === 0) {
  throw new Error(
    "journeys/day-1.md contains no `## Step N` headings — Day-1 layout requires step segmentation.",
  );
}

const processor = await createMarkdownProcessor({
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  remarkPlugins: [
    [
      remarkGlossaryLink as any,
      { glossaryDir: '../glossary', excludePaths: ['/news/published/'] },
    ],
  ],
});

const renderedSteps = await Promise.all(
  steps.map(async (step) => {
    const result = await processor.render(step.bodyMd);
    return { ...step, html: result.code };
  }),
);

const introHtml = intro.length > 0 ? (await processor.render(intro)).code : '';

// Short TOC labels — chosen to fit the 240px sidebar without wrapping.
// Order must match the step order in journeys/day-1.md.
const tocLabels: Record<number, string> = {
  1: 'Open a terminal',
  2: 'Install Claude Code',
  3: 'GitHub account',
  4: 'First session',
  5: 'Write CLAUDE.md',
  6: 'Survival keys',
};

const heroTitle = entry.data.title ?? 'Day 1';
const heroSummary = entry.data.ai_summary;
---

<MarketingShell
  title={heroTitle}
  description={heroSummary}
  surfaceId="day-1"
  width="full"
  hero="none"
  mode="reader"
>
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Where to start, <em>practically</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms(heroSummary)} />
          <small>Audience: {entry.data.audience} · ~30 min · {renderedSteps.length} steps</small>
        </p>
      </div>
      <nav class="journey-overview" aria-label="Day 1 steps">
        <ol>
          {renderedSteps.map((step) => (
            <li>
              <a href={`#d${step.n}`} data-step-id={`d${step.n}`}>
                <span class="journey-overview__num">{String(step.n).padStart(2, '0')}</span>
                <span class="journey-overview__label" set:html={step.title.replace(/`([^`]+)`/g, '<code>$1</code>')} />
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  {introHtml.length > 0 && (
    <section class="day-intro-section" id="intro">
      <div class="wrap">
        <div class="journey-intro sl-markdown-content" set:html={introHtml} />
      </div>
    </section>
  )}

  <div class="day-layout wrap">
    <aside class="day-toc" aria-label="Day 1 steps">
      <div class="day-toc__inner">
        <span class="day-toc__eyebrow">Steps</span>
        <nav>
          <ol class="day-toc__list">
            {renderedSteps.map((step) => (
              <li>
                <a href={`#d${step.n}`} data-toc-target={`d${step.n}`}>
                  <span class="day-toc__label">{tocLabels[step.n] ?? step.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
        <a class="day-toc__skip" href="/tips/">→ Skip to Tips &amp; tricks</a>
      </div>
    </aside>

    <div class="day-main">
      {renderedSteps.map((step) => (
        <section
          class="day-section"
          id={`d${step.n}`}
          data-step={step.n}
          aria-label={`Step ${step.n}: ${step.title}`}
        >
          <header class="day-section__head">
            <h2 class="day-section__title" set:html={step.title.replace(/`([^`]+)`/g, '<code>$1</code>')} />
          </header>

          {step.n === 5 && (
            <figure
              class="claudemd-figure"
              aria-label="Without a CLAUDE.md, the same prompt produces three different reports across three runs. With a CLAUDE.md, the same prompt produces three identical reports."
            >
              <div class="claudemd-figure__panels">
                <article class="claudemd-panel claudemd-panel--without">
                  <header class="claudemd-panel__head">
                    <span class="claudemd-panel__eyebrow claudemd-panel__eyebrow--warn">Without CLAUDE.md</span>
                  </header>
                  <div class="claudemd-panel__inputs">
                    <div class="claudemd-icon">
                      <svg class="claudemd-icon__svg" viewBox="0 0 24 24" aria-hidden="true">
                        <rect class="claudemd-icon__page" x="3" y="3" width="18" height="18" rx="2" />
                        <line class="claudemd-icon__line" x1="3" y1="9" x2="21" y2="9" />
                        <line class="claudemd-icon__line" x1="9" y1="3" x2="9" y2="21" />
                        <line class="claudemd-icon__line" x1="15" y1="3" x2="15" y2="21" />
                        <line class="claudemd-icon__line" x1="3" y1="15" x2="21" y2="15" />
                      </svg>
                      <span class="claudemd-icon__label">loans.xlsx</span>
                    </div>
                  </div>
                  <div class="claudemd-panel__prompt">
                    <span class="claudemd-panel__prompt-text">"analyse + report"</span>
                  </div>
                  <div class="claudemd-panel__arrow" aria-hidden="true">↓</div>
                  <div class="claudemd-panel__outputs">
                    <div class="claudemd-output">
                      <svg class="claudemd-glyph claudemd-glyph--varied" viewBox="0 0 40 52" aria-hidden="true">
                        <rect class="claudemd-glyph__page" x="4" y="8" width="32" height="38" rx="2" />
                        <line class="claudemd-glyph__line" x1="8" y1="16" x2="28" y2="16" />
                        <line class="claudemd-glyph__line" x1="8" y1="22" x2="20" y2="22" />
                        <line class="claudemd-glyph__line" x1="8" y1="28" x2="32" y2="28" />
                        <line class="claudemd-glyph__line" x1="8" y1="34" x2="24" y2="34" />
                        <line class="claudemd-glyph__line" x1="8" y1="40" x2="30" y2="40" />
                      </svg>
                      <span class="claudemd-output__label">Run 1</span>
                    </div>
                    <div class="claudemd-output">
                      <svg class="claudemd-glyph claudemd-glyph--varied" viewBox="0 0 40 52" aria-hidden="true">
                        <rect class="claudemd-glyph__page" x="6" y="2" width="28" height="48" rx="2" />
                        <line class="claudemd-glyph__line" x1="10" y1="12" x2="30" y2="12" />
                        <line class="claudemd-glyph__line" x1="10" y1="22" x2="22" y2="22" />
                        <line class="claudemd-glyph__line" x1="10" y1="32" x2="28" y2="32" />
                        <line class="claudemd-glyph__line" x1="10" y1="42" x2="18" y2="42" />
                      </svg>
                      <span class="claudemd-output__label">Run 2</span>
                    </div>
                    <div class="claudemd-output">
                      <svg class="claudemd-glyph claudemd-glyph--varied" viewBox="0 0 40 52" aria-hidden="true">
                        <rect class="claudemd-glyph__page" x="3" y="4" width="34" height="44" rx="2" />
                        <rect class="claudemd-glyph__title" x="7" y="9" width="20" height="3" rx="0.5" />
                        <line class="claudemd-glyph__line" x1="7" y1="18" x2="33" y2="18" />
                        <line class="claudemd-glyph__line" x1="7" y1="24" x2="27" y2="24" />
                        <line class="claudemd-glyph__line" x1="7" y1="30" x2="33" y2="30" />
                        <line class="claudemd-glyph__line" x1="7" y1="36" x2="22" y2="36" />
                        <line class="claudemd-glyph__line" x1="7" y1="42" x2="30" y2="42" />
                      </svg>
                      <span class="claudemd-output__label">Run 3</span>
                    </div>
                  </div>
                  <p class="claudemd-panel__caption claudemd-panel__caption--warn">Every run reinvents the wheel.</p>
                </article>

                <article class="claudemd-panel claudemd-panel--with">
                  <header class="claudemd-panel__head">
                    <span class="claudemd-panel__eyebrow claudemd-panel__eyebrow--accent">With CLAUDE.md</span>
                  </header>
                  <div class="claudemd-panel__inputs">
                    <div class="claudemd-icon">
                      <svg class="claudemd-icon__svg" viewBox="0 0 24 24" aria-hidden="true">
                        <rect class="claudemd-icon__page" x="3" y="3" width="18" height="18" rx="2" />
                        <line class="claudemd-icon__line" x1="3" y1="9" x2="21" y2="9" />
                        <line class="claudemd-icon__line" x1="9" y1="3" x2="9" y2="21" />
                        <line class="claudemd-icon__line" x1="15" y1="3" x2="15" y2="21" />
                        <line class="claudemd-icon__line" x1="3" y1="15" x2="21" y2="15" />
                      </svg>
                      <span class="claudemd-icon__label">loans.xlsx</span>
                    </div>
                    <div class="claudemd-icon claudemd-icon--accent">
                      <svg class="claudemd-icon__svg" viewBox="0 0 24 24" aria-hidden="true">
                        <path class="claudemd-icon__page" d="M5 3 L15 3 L20 8 L20 21 L5 21 Z" />
                        <path class="claudemd-icon__fold" d="M15 3 L15 8 L20 8" />
                        <line class="claudemd-icon__line" x1="9" y1="13" x2="17" y2="13" />
                        <line class="claudemd-icon__line" x1="9" y1="16" x2="15" y2="16" />
                        <line class="claudemd-icon__line" x1="9" y1="19" x2="17" y2="19" />
                      </svg>
                      <span class="claudemd-icon__label">CLAUDE.md</span>
                    </div>
                  </div>
                  <div class="claudemd-panel__prompt">
                    <span class="claudemd-panel__prompt-text">"analyse + report"</span>
                  </div>
                  <div class="claudemd-panel__arrow" aria-hidden="true">↓</div>
                  <div class="claudemd-panel__outputs">
                    {[1, 2, 3].map((n) => (
                      <div class="claudemd-output">
                        <svg class="claudemd-glyph claudemd-glyph--consistent" viewBox="0 0 40 52" aria-hidden="true">
                          <rect class="claudemd-glyph__page" x="4" y="2" width="32" height="48" rx="2" />
                          <rect class="claudemd-glyph__title" x="8" y="8" width="18" height="3" rx="0.5" />
                          <line class="claudemd-glyph__line" x1="8" y1="17" x2="32" y2="17" />
                          <line class="claudemd-glyph__line" x1="8" y1="23" x2="28" y2="23" />
                          <line class="claudemd-glyph__line" x1="8" y1="29" x2="32" y2="29" />
                          <line class="claudemd-glyph__line" x1="8" y1="35" x2="26" y2="35" />
                          <line class="claudemd-glyph__line" x1="8" y1="41" x2="32" y2="41" />
                        </svg>
                        <span class="claudemd-output__label">Run {n}</span>
                      </div>
                    ))}
                  </div>
                  <p class="claudemd-panel__caption claudemd-panel__caption--accent">Same output, every time.</p>
                </article>
              </div>
              <figcaption class="claudemd-figure__caption">
                Same folder, same prompt. The only difference is <code>CLAUDE.md</code>.
              </figcaption>
            </figure>
          )}

          <div class="day-section__prose">
            <div class="day-section__body sl-markdown-content" set:html={step.html} />
          </div>
        </section>
      ))}
    </div>
  </div>

  <section class="day-next" id="next">
    <div class="wrap">
      <article class="day-next__card">
        <div class="day-next__body">
          <span class="day-next__eyebrow">Next →</span>
          <h2 class="day-next__title">Tips &amp; tricks</h2>
          <p class="day-next__lede" set:html={linkGlossaryTerms("You've installed, signed in, run your first session, and put a CLAUDE.md down. Now the habits that compound — prompting patterns, survival keys, context discipline, the small moves that take a user from working to fast.")} />
          <div class="day-next__actions">
            <a class="day-next__cta day-next__cta--primary" href="/tips/">
              Open Tips →
            </a>
            <a class="day-next__cta day-next__cta--secondary" href="/glossary/">
              Or look up a term ({glossaryCount} in the glossary)
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>
</MarketingShell>

<script is:inline>
  // Drives both the top `.journey-overview` cards AND the sticky `.day-toc`
  // sidebar. One IntersectionObserver, two highlights kept in sync.
  (function () {
    var overviewLinks = Array.from(document.querySelectorAll('.journey-overview [data-step-id]'));
    var tocLinks = Array.from(document.querySelectorAll('.day-toc [data-toc-target]'));
    var sections = Array.from(document.querySelectorAll('.day-section[id]'));
    if (!sections.length) return;

    function setActive(id) {
      overviewLinks.forEach(function (a) {
        var li = a.closest('li');
        if (li) li.dataset.current = a.dataset.stepId === id ? 'true' : 'false';
      });
      tocLinks.forEach(function (a) {
        if (a.getAttribute('data-toc-target') === id) a.setAttribute('data-active', '');
        else a.removeAttribute('data-active');
      });
    }
    setActive(sections[0].id);

    if (!('IntersectionObserver' in window)) return;
    var observer = new IntersectionObserver(function (entries) {
      var visible = entries
        .filter(function (e) { return e.isIntersecting; })
        .sort(function (a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
      if (visible.length) setActive(visible[0].target.id);
    }, { rootMargin: '-25% 0px -60% 0px', threshold: 0 });
    sections.forEach(function (s) { observer.observe(s); });
  })();
</script>

<style>
  @layer nbg.components {
    /* ─── Intro under hero ─────────────────────────────────────── */
    /* Custom class (not `.section`) — avoids agentnews-layout's
       `.section { padding-block: ... }` unlayered rule overriding us. */
    .day-intro-section {
      padding-block: 1rem !important;
    }
    .journey-intro {
      color: var(--nbg-ink-2);
      font-size: 1.125rem;
      line-height: 1.7;
    }
    .journey-intro :global(p) {
      margin: 0 0 1rem 0 !important;
    }
    .journey-intro :global(p:last-child) {
      margin-bottom: 0 !important;
    }
    /* Hide markdown `---` separators inside the intro — local renders them
       with browser-default 32px top+bottom margins (deployed has Starlight's
       16/0 rule applying). Different visual height on local vs deploy. The
       separator adds no value in the docs-style layout — kill it both sides. */
    .journey-intro :global(hr) {
      display: none !important;
    }

    /* ─── Top 5-card overview (kept from prior layout) ─────────── */
    .journey-overview {
      margin-top: 2rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--nbg-hairline);
    }
    .journey-overview ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .journey-overview li { margin: 0; }
    .journey-overview a {
      display: flex;
      align-items: flex-start;
      gap: 0.625rem;
      padding: 0.875rem 0.875rem 1rem;
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-surface);
      color: var(--nbg-ink-2);
      text-decoration: none;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
      height: 100%;
    }
    .journey-overview a:hover {
      border-color: color-mix(in srgb, var(--nbg-accent) 50%, var(--nbg-hairline));
      background: color-mix(in srgb, var(--nbg-accent) 4%, var(--nbg-surface));
      transform: translateY(-1px);
    }
    .journey-overview a:focus-visible {
      outline: 2px solid var(--nbg-accent);
      outline-offset: 2px;
    }
    .journey-overview li[data-current='true'] a {
      border-color: var(--nbg-accent);
      background: color-mix(in srgb, var(--nbg-accent) 8%, var(--nbg-surface));
    }
    .journey-overview__num {
      font-family: var(--nbg-ff-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      color: var(--nbg-accent);
      font-weight: 600;
      padding-top: 0.1rem;
      flex: 0 0 auto;
    }
    .journey-overview__label {
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      line-height: 1.3;
      color: var(--nbg-ink);
      letter-spacing: -0.005em;
    }
    .journey-overview__label :global(code) {
      font-family: var(--nbg-ff-mono);
      font-size: 0.875em;
      background: var(--nbg-surface-2);
      padding: 0.05em 0.3em;
      border-radius: var(--nbg-r-sm);
    }
    @media (max-width: 75rem) {
      .journey-overview ol { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @media (max-width: 48rem) {
      .journey-overview ol { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 30rem) {
      .journey-overview ol { grid-template-columns: 1fr; gap: 0.5rem; }
      .journey-overview a { padding: 0.75rem 0.875rem; }
    }

    /* ─── Two-column docs layout ───────────────────────────────── */
    /* !important on layout spacing — unlayered Starlight/agentnews-layout
       rules on `.wrap` and `.section` beat our @layer rules in production. */
    .day-layout {
      display: grid !important;
      grid-template-columns: 240px minmax(0, 1fr) !important;
      gap: 3rem !important;
      padding-block: 1rem 2rem !important;
      align-items: start !important;
    }
    @media (max-width: 960px) {
      .day-layout {
        grid-template-columns: 1fr !important;
        gap: 1.5rem !important;
      }
    }

    /* ─── Sticky TOC sidebar ───────────────────────────────────── */
    .day-toc {
      position: sticky;
      top: 5rem;
      align-self: start;
    }
    @media (max-width: 960px) {
      .day-toc {
        position: static;
        border: 1px solid var(--nbg-hairline);
        border-radius: var(--nbg-r-md, 8px);
        padding: 1rem;
        background: var(--nbg-surface);
      }
    }
    .day-toc__inner {
      display: flex !important;
      flex-direction: column !important;
      gap: 1rem !important;
    }
    .day-toc__eyebrow {
      font-family: var(--nbg-ff-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--nbg-muted);
      font-weight: 500;
    }
    .day-toc__list {
      list-style: none !important;
      margin: 0 !important;
      padding: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 0.125rem !important;
      border-left: 2px solid var(--nbg-hairline) !important;
    }
    .day-toc__list a {
      display: block;
      padding: 0.5rem 0.75rem;
      margin-left: -2px;
      border-left: 2px solid transparent;
      color: var(--nbg-muted);
      text-decoration: none;
      font-size: 0.875rem;
      line-height: 1.35;
      transition: color 120ms ease, border-color 120ms ease;
    }
    .day-toc__list a:hover { color: var(--nbg-ink); }
    .day-toc__list a[data-active] {
      color: var(--nbg-accent);
      border-left-color: var(--nbg-accent);
      font-weight: 600;
    }
    .day-toc__skip {
      font-family: var(--nbg-ff-mono);
      font-size: 0.75rem;
      color: var(--nbg-accent);
      text-decoration: none;
      padding-top: 0.75rem;
      border-top: 1px solid var(--nbg-hairline);
      letter-spacing: 0.04em;
    }
    .day-toc__skip:hover { text-decoration: underline; }

    /* ─── Main column sections ─────────────────────────────────── */
    .day-main {
      display: flex !important;
      flex-direction: column !important;
      gap: 4rem !important;
      min-width: 0 !important;
    }
    @media (max-width: 960px) {
      .day-main { gap: 3rem !important; }
    }
    .day-section {
      padding: 0 !important;
      scroll-margin-top: 5rem !important;
    }
    .day-section__head {
      margin-bottom: 1.5rem !important;
      padding-bottom: 1rem !important;
      border-bottom: 1px solid var(--nbg-hairline) !important;
    }
    /* !important + compound selector required — Starlight's unlayered
