---
/**
 * /start-here/foundations — docs-style scrollable layout.
 *
 * Renders journeys/foundations.md as six full-bleed sections with a sticky
 * left-rail TOC. Replaces the prior accordion-per-section model (2026-05-27
 * UAT — accordions deflated the script's voice and hid content). New
 * structure rewards linear reading; the sticky TOC keeps the skeleton
 * visible without the click-to-reveal friction.
 *
 * Per-section visuals:
 *   F2 — animated glass-of-water (the metaphor the script leans on hardest)
 *   F3 — side-by-side chatbot/agent comparison
 *   F4–F6 — prose only (table inside F5/F6 markdown is sufficient)
 *
 * Resources move from "behind the expand" into a visible card row at the
 * end of each section. Discoverable without clicking.
 *
 * Active-section tracking: IntersectionObserver toggles `data-active` on
 * matching TOC links as sections scroll into view.
 */
import { getEntry, getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import MarketingShell from '../../components/MarketingShell.astro';
import remarkGlossaryLink from '../../plugins/remark-glossary-link.ts';
import { linkGlossaryTerms } from '../../lib/glossary-link-string';

const glossaryCount = (await getCollection('glossary')).length;

const entry = await getEntry('journeys', 'foundations');
if (!entry) {
  throw new Error(
    "Missing journeys collection entry 'foundations' — expected at /journeys/foundations.md",
  );
}

const rawBody: string | undefined = entry.body;
if (typeof rawBody !== 'string' || rawBody.trim().length === 0) {
  throw new Error(
    'journeys/foundations.md has an empty body — expected `## Step N` segmented content.',
  );
}

interface ParsedStep {
  n: number;
  title: string;
  bodyMd: string;
}

function splitSteps(body: string): { intro: string; steps: ParsedStep[] } {
  const lines = body.split('\n');
  const headingRe = /^##\s+Step\s+(\d+)\s*[—\-]\s*(.+?)\s*$/;
  const introLines: string[] = [];
  const steps: ParsedStep[] = [];
  let current: ParsedStep | null = null;
  for (const line of lines) {
    const match = line.match(headingRe);
    if (match && match[1] && match[2]) {
      if (current) steps.push(current);
      current = { n: Number.parseInt(match[1], 10), title: match[2], bodyMd: '' };
      continue;
    }
    if (current) {
      current.bodyMd += (current.bodyMd ? '\n' : '') + line;
    } else {
      introLines.push(line);
    }
  }
  if (current) steps.push(current);
  for (const step of steps) {
    step.bodyMd = step.bodyMd.replace(/\n---\s*\n?\s*$/, '\n').trim();
  }
  return { intro: introLines.join('\n').trim(), steps };
}

const { intro, steps } = splitSteps(rawBody);

const processor = await createMarkdownProcessor({
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  remarkPlugins: [
    [
      remarkGlossaryLink as any,
      { glossaryDir: '../glossary', excludePaths: ['/news/published/'] },
    ],
  ],
});
const renderedSteps = await Promise.all(
  steps.map(async (step) => {
    const result = await processor.render(step.bodyMd);
    return { ...step, html: result.code };
  }),
);
const introHtml = intro.length > 0 ? (await processor.render(intro)).code : '';

// TOC labels — shortened from the full step titles to fit the sidebar.
// Order must match the step order in journeys/foundations.md.
const tocLabels: Record<number, string> = {
  1: 'What is an LLM?',
  2: 'Context windows',
  3: 'Agent vs chatbot',
  4: 'What is Claude Code?',
  5: 'vs Claude.ai, API, ChatGPT',
  6: 'Why Claude Code?',
};

interface Resource {
  step: number;
  title: string;
  author: string;
  kind: 'video' | 'article' | 'course' | 'docs';
  duration?: string;
  url: string;
  why: string;
}

// 2026-05-27 reshuffle: step order is concept → product → choice.
// Resource step keys remapped to match. Old → new step number mapping:
//   1 (Claude Code)  → 4
//   2 (vs ChatGPT)   → 5
//   3 (LLM)          → 1
//   4 (Context)      → 2
//   5 (Agent)        → 3
//   6 (Why CC)       → 6  (unchanged)
const resources: Resource[] = [
  // F1 — What is an LLM
  { step: 1, kind: 'video', title: 'Large Language Models Explained Briefly', author: '3Blue1Brown', duration: '~10 min',
    url: 'https://www.youtube.com/watch?v=LPZh9BOjkQs',
    why: 'The single best 10-minute explainer ever produced. Visual, accurate, no jargon. If you only watch one thing on this page, watch this.' },
  { step: 1, kind: 'video', title: '[1hr Talk] Intro to Large Language Models', author: 'Andrej Karpathy', duration: '~60 min',
    url: 'https://www.youtube.com/watch?v=zjkBMFhNj_g',
    why: 'Andrej Karpathy was at OpenAI and Tesla. This is the deeper version. Covers what LLMs are, where they\'re going, security implications. Generally considered required watching in the field.' },
  { step: 1, kind: 'article', title: 'Transformers, the tech behind LLMs — Chapter 5', author: '3Blue1Brown',
    url: 'https://www.3blue1brown.com/lessons/gpt/',
    why: 'If the 10-minute version left you wanting more — this is the visual deep-dive into how transformers actually work.' },

  // F2 — Context windows
  { step: 2, kind: 'docs', title: 'What is a context window?', author: 'IBM Think',
    url: 'https://www.ibm.com/think/topics/context-window',
    why: 'Vendor-neutral, technically careful explanation. Defines the term, explains the trade-offs, links to deeper reading.' },
  { step: 2, kind: 'article', title: 'Context Window Limits: Why Your LLM Still Hallucinates', author: 'Perivitta Rajendran',
    url: 'https://pr-peri.github.io/llm/2026/02/13/why-hallucination-happens.html',
    why: 'Connects the context-window mechanic directly to hallucination behaviour — the practical "why does Claude start making things up?" answer.' },
  { step: 2, kind: 'article', title: 'When More Becomes Less — Why LLMs Hallucinate in Long Contexts', author: 'Rishabh Bhandari (Bootcamp / Medium)',
    url: 'https://medium.com/design-bootcamp/when-more-becomes-less-why-llms-hallucinate-in-long-contexts-fc903be6f025',
    why: 'Covers the "lost in the middle" phenomenon — why even large context windows don\'t solve forgetting cleanly.' },

  // F3 — Agent vs chatbot
  { step: 3, kind: 'article', title: 'What Is An AI Agent? And Is It the Same as a Chatbot?', author: 'Forethought',
    url: 'https://forethought.ai/blog/what-is-an-ai-agent',
    why: 'Plain-English breakdown of agent autonomy + tool use vs scripted chatbot decision trees. Good for non-technical readers.' },
  { step: 3, kind: 'article', title: 'What Is the Claude Agent SDK? How It Differs from the Claude API', author: 'MindStudio',
    url: 'https://www.mindstudio.ai/blog/what-is-claude-agent-sdk-vs-claude-api',
    why: 'Maps the agent-loop concept onto Anthropic\'s specific products. Explains why Claude Code "feels different" from calling the API yourself.' },

  // F4 — What is Claude Code?
  { step: 4, kind: 'course', title: 'Claude Code 101', author: 'Anthropic (official)',
    url: 'https://anthropic.skilljar.com/claude-code-101',
    why: 'Anthropic\'s own beginner course — installation through advanced customisation. The most authoritative starting point. Free.' },
  { step: 4, kind: 'video', title: 'Claude Code — Full Tutorial for Beginners', author: 'Tech with Tim', duration: '~45 min',
    url: 'https://www.youtube.com/watch?v=ntDIxaeo3Wg',
    why: 'Hands-on walkthrough of the actual CLI experience. Watch this before you install if you want to see what you\'re signing up for.' },
  { step: 4, kind: 'video', title: 'How Anthropic Employees ACTUALLY Use Claude Code', author: 'Anthropic', duration: '~25 min',
    url: 'https://www.youtube.com/watch?v=pRfIWmddRsE',
    why: 'Non-technical Anthropic staff showing real workflows. Useful for non-developers who want to see the breadth of use cases.' },

  // F5 — Claude product disambiguation
  { step: 5, kind: 'article', title: 'Claude, Claude API, and Claude Code: What\'s the Difference?', author: '16x.engineer',
    url: 'https://eval.16x.engineer/blog/claude-vs-claude-api-vs-claude-code',
    why: 'Clearest single-page disambiguation of the three surfaces. Read this if the names are blurring together.' },
  { step: 5, kind: 'article', title: '5 Claude Products: Which One Do You Actually Need?', author: 'RSL/A',
    url: 'https://rsla.io/blog/anthropic-claude-products-guide',
    why: 'Covers the full product family including Desktop and Cowork. Decision-tree shaped — match your job to the right surface.' },

  // F6 — Why Claude Code specifically
  { step: 6, kind: 'article', title: 'Every AI Coding CLI in 2026: The Complete Map (30+ Tools Compared)', author: 'DEV Community',
    url: 'https://dev.to/soulentheo/every-ai-coding-cli-in-2026-the-complete-map-30-tools-compared-4gob',
    why: 'Most comprehensive 2026 landscape overview. Useful for understanding *what else exists* before deciding Claude Code is right.' },
  { step: 6, kind: 'article', title: 'Claude Code vs Cursor: What to Choose in 2026', author: 'Builder.io',
    url: 'https://www.builder.io/blog/cursor-vs-claude-code',
    why: 'Head-to-head with the closest competitor. Honest about where Cursor wins (visual editing) and where Claude Code wins (autonomous multi-file work).' },
  { step: 6, kind: 'article', title: 'Coding Agents Comparison — independent benchmarks', author: 'Artificial Analysis',
    url: 'https://artificialanalysis.ai/agents/coding',
    why: 'Third-party benchmark numbers — not vendor marketing. Useful for "is the hype real" questions.' },
];

const heroTitle = entry.data.title ?? 'Foundations';
const heroSummary = entry.data.ai_summary;

function resourceKindLabel(kind: Resource['kind']): string {
  switch (kind) {
    case 'video':   return 'Video';
    case 'article': return 'Article';
    case 'course':  return 'Course';
    case 'docs':    return 'Docs';
  }
}
function resourceKindTone(kind: Resource['kind']): string {
  switch (kind) {
    case 'video':   return 'tag--link';
    case 'article': return '';
    case 'course':  return 'tag--audience-beginner';
    case 'docs':    return 'tag--audience-both';
  }
}
---

<MarketingShell
  title={heroTitle}
  description={heroSummary}
  surfaceId="foundations"
  width="full"
  hero="none"
  mode="reader"
>
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Foundations, <em>before your first session</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms(heroSummary)} />
          <small>Audience: complete beginner · ~20 min read · 16 curated external resources</small>
          <small><a href="/start-here/day-1/">→ ready to install? Skip to Day 1</a></small>
        </p>
      </div>
      <nav class="journey-overview" aria-label="Foundations sections">
        <ol>
          {renderedSteps.map((step) => (
            <li>
              <a href={`#f${step.n}`} data-step-id={`f${step.n}`}>
                <span class="journey-overview__num">{String(step.n).padStart(2, '0')}</span>
                <span class="journey-overview__label">{tocLabels[step.n] ?? step.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </section>

  {introHtml.length > 0 && (
    <section class="foundation-intro-section" id="intro">
      <div class="wrap">
        <div class="journey-intro sl-markdown-content" set:html={introHtml} />
      </div>
    </section>
  )}

  {/* Two-column main: sticky TOC | scrollable sections */}
  <div class="foundation-layout wrap">
    <aside class="foundation-toc" aria-label="Foundations sections">
      <div class="foundation-toc__inner">
        <span class="foundation-toc__eyebrow">Sections</span>
        <nav>
          <ol class="foundation-toc__list">
            {renderedSteps.map((step) => (
              <li>
                <a href={`#f${step.n}`} data-toc-target={`f${step.n}`}>
                  <span class="foundation-toc__label">{tocLabels[step.n] ?? step.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </nav>
        <a class="foundation-toc__skip" href="/start-here/day-1/">→ Skip to Day 1</a>
      </div>
    </aside>

    <div class="foundation-main">
      {renderedSteps.map((step) => {
        const stepResources = resources.filter((r) => r.step === step.n);
        return (
          <section
            class="foundation-section"
            id={`f${step.n}`}
            data-step={step.n}
            aria-label={`Foundation ${step.n}: ${step.title}`}
          >
            <header class="foundation-section__head">
              <h2 class="foundation-section__title">{step.title}</h2>
            </header>

            {/* F2 — glass-of-water visual. Three glasses, increasing
                fill, mapping to the metaphor's three states. */}
            {step.n === 2 && (
              <figure class="glass-figure" aria-label="Three glasses of water at increasing fill levels, illustrating how a context window fills up over a session.">
                <div class="glass-row">
                  <div class="glass-cell">
                    <svg class="glass-svg" viewBox="0 0 80 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <defs>
                        <clipPath id="g1-clip"><path d="M14 8 L66 8 L60 110 L20 110 Z" /></clipPath>
                      </defs>
                      <rect class="glass-water" x="14" y="80" width="52" height="30" clip-path="url(#g1-clip)" />
                      <path class="glass-outline" d="M14 8 L66 8 L60 110 L20 110 Z" />
                      <line class="glass-rim" x1="14" y1="8" x2="66" y2="8" />
                    </svg>
                    <span class="glass-label">~30% full</span>
                    <span class="glass-caption">Start of session. Plenty of room.</span>
                  </div>
                  <div class="glass-cell">
                    <svg class="glass-svg" viewBox="0 0 80 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <defs>
                        <clipPath id="g2-clip"><path d="M14 8 L66 8 L60 110 L20 110 Z" /></clipPath>
                      </defs>
                      <rect class="glass-water" x="14" y="40" width="52" height="70" clip-path="url(#g2-clip)" />
                      <path class="glass-outline" d="M14 8 L66 8 L60 110 L20 110 Z" />
                      <line class="glass-rim" x1="14" y1="8" x2="66" y2="8" />
                    </svg>
                    <span class="glass-label glass-label--warn">~70% full</span>
                    <span class="glass-caption">Trust nothing past here without re-reading.</span>
                  </div>
                  <div class="glass-cell">
                    <svg class="glass-svg" viewBox="0 0 80 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <defs>
                        <clipPath id="g3-clip"><path d="M14 8 L66 8 L60 110 L20 110 Z" /></clipPath>
                      </defs>
                      <rect class="glass-water" x="14" y="14" width="52" height="96" clip-path="url(#g3-clip)" />
                      <path class="glass-outline" d="M14 8 L66 8 L60 110 L20 110 Z" />
                      <line class="glass-rim" x1="14" y1="8" x2="66" y2="8" />
                      <circle class="glass-drop" cx="10" cy="14" r="2" />
                      <circle class="glass-drop" cx="70" cy="18" r="1.5" />
                      <circle class="glass-drop" cx="8" cy="22" r="1.5" />
                    </svg>
                    <span class="glass-label glass-label--bad">~100% full</span>
                    <span class="glass-caption">Oldest water spills. The model "forgets".</span>
                  </div>
                </div>
                <figcaption class="glass-figcaption">
                  <code>/compact</code> squeezes the conversation into a summary.
                  <code>/clear</code> empties the glass entirely. When in doubt, clear.
                </figcaption>
              </figure>
            )}

            <div class="foundation-step">
              <div class="foundation-step__body sl-markdown-content" set:html={step.html} />
            </div>

            {/* F3 — side-by-side flow comparison. Two columns, aligned
                step-by-step so the divergence reads at a glance. */}
            {step.n === 3 && (
              <div class="foundation-compare" aria-label="Side-by-side comparison: chatbot flow vs agent flow.">
                <article class="foundation-compare__col foundation-compare__col--chatbot">
                  <header>
                    <span class="foundation-compare__eyebrow">Chatbot flow</span>
                    <h3>ChatGPT-style — you're the integrator</h3>
                  </header>
                  <ol class="foundation-compare__steps">
                    <li>You paste your code into the chat tab</li>
                    <li>The model proposes a fix</li>
                    <li>You copy the fix back into your editor</li>
                    <li>You run the test — it fails</li>
                    <li>You paste the error message back into chat</li>
                    <li>It forgets your project next time you open the tab</li>
                  </ol>
                </article>
                <article class="foundation-compare__col foundation-compare__col--agent">
                  <header>
                    <span class="foundation-compare__eyebrow">Agent flow</span>
                    <h3>Claude Code-style — you supervise</h3>
                  </header>
                  <ol class="foundation-compare__steps">
                    <li>You describe what you want, in plain English</li>
                    <li>The model reads the relevant files itself</li>
                    <li>It edits the files directly, with your approval</li>
                    <li>It runs the test, sees the failure</li>
                    <li>It iterates on its own — usually fixes it</li>
                    <li>It remembers via <code>CLAUDE.md</code> next time</li>
                  </ol>
                </article>
              </div>
            )}

            {stepResources.length > 0 && (
              <div class="foundation-resources">
                <div class="foundation-resources__head">
                  <span class="eyebrow eyebrow--accent">Watch / read</span>
                  <span class="count">{stepResources.length} curated</span>
                </div>
                <div class="grid-3">
                  {stepResources.map((r) => (
                    <article class="card card--text">
                      <div class="card__body">
                        <div class="card__meta">
                          <span class={`tag ${resourceKindTone(r.kind)}`}>{resourceKindLabel(r.kind)}</span>
                          {r.duration && <span class="external-host">{r.duration}</span>}
                        </div>
                        <h4 class="card__title">
                          <a href={r.url} target="_blank" rel="noopener noreferrer">
                            {r.title}
                          </a>
                        </h4>
                        <p class="card__summary"><strong>{r.author}</strong> — {r.why}</p>
                        <a class="feature__cta" href={r.url} target="_blank" rel="noopener noreferrer">
                          Open →
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </div>
            )}
          </section>
        );
      })}
    </div>
  </div>

  {/* Prominent Day 1 handoff — the single most important link on this page. */}
  <section class="foundation-next" id="next">
    <div class="wrap">
      <article class="foundation-next__card">
        <div class="foundation-next__body">
          <span class="foundation-next__eyebrow">Next →</span>
          <h2 class="foundation-next__title">Day 1 — your first session</h2>
          <p class="foundation-next__lede" set:html={linkGlossaryTerms("You've got the mental models. Now install Claude Code and run your first session — five concrete steps, about thirty minutes, productive by the end of it.")} />
          <div class="foundation-next__actions">
            <a class="foundation-next__cta foundation-next__cta--primary" href="/start-here/day-1/">
              Open Day 1 →
            </a>
            <a class="foundation-next__cta foundation-next__cta--secondary" href="/glossary/">
              Or look up a term ({glossaryCount} in the glossary)
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>
</MarketingShell>

<script is:inline>
  // Active-section tracking: highlight the TOC link whose target section
  // is currently centred-ish in the viewport. rootMargin pushes the
  // "active band" to ~30% from the top so a section becomes active when
  // its heading is in the upper third of the viewport.
  (function () {
    const links = Array.from(document.querySelectorAll('.foundation-toc [data-toc-target]'));
    const overviewLinks = Array.from(document.querySelectorAll('.journey-overview [data-step-id]'));
    if (!links.length && !overviewLinks.length) return;
    function setActive(id) {
      links.forEach(function (a) {
        if (a.getAttribute('data-toc-target') === id) a.setAttribute('data-active', '');
        else a.removeAttribute('data-active');
      });
      overviewLinks.forEach(function (a) {
        const li = a.closest('li');
        if (li) li.dataset.current = a.dataset.stepId === id ? 'true' : 'false';
      });
    }
    const sections = Array.from(document.querySelectorAll('.foundation-section[id]'));
    if (!sections.length) return;
    // Initial: first section active.
    setActive(sections[0].id);
    if (!('IntersectionObserver' in window)) return;
    const observer = new IntersectionObserver(function (entries) {
      // Find the entry closest to the top edge of the viewport that's
      // intersecting. Falls back to the last-known section.
      const visible = entries
        .filter(function (e) { return e.isIntersecting; })
        .sort(function (a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });
      if (visible.length) setActive(visible[0].target.id);
    }, { rootMargin: '-25% 0px -60% 0px', threshold: 0 });
    sections.forEach(function (s) { observer.observe(s); });
  })();
</script>

<style>
  @layer nbg.components {
    /* ─── Hero / intro ─────────────────────────────────────────── */
    /* Custom class (not `.section`) — avoids agentnews-layout's
       `.section { padding-block: ... }` unlayered rule overriding us. */
    .foundation-intro-section {
      padding-block: 1rem !important;
    }
    .journey-intro {
      color: var(--nbg-ink-2);
      font-size: 1.125rem;
      line-height: 1.7;
    }
    .journey-intro :global(p) {
      margin: 0 0 1rem 0 !important;
    }
    .journey-intro :global(p:last-child) {
      margin-bottom: 0 !important;
    }
    /* Hide markdown `---` separators inside the intro — local renders them
       with browser-default 32px top+bottom margins (deployed has Starlight's
       16/0 rule applying). Different visual height on local vs deploy. The
       separator adds no value in the docs-style layout — kill it both sides. */
    .journey-intro :global(hr) {
      display: none !important;
    }

    /* ─── Top 6-card section overview (mirrors Day 1) ─────────── */
    .journey-overview {
      margin-top: 2rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--nbg-hairline);
    }
    .journey-overview ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .journey-overview li { margin: 0; }
    .journey-overview a {
      display: flex;
      align-items: flex-start;
      gap: 0.625rem;
      padding: 0.875rem 0.875rem 1rem;
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-surface);
      color: var(--nbg-ink-2);
      text-decoration: none;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
      height: 100%;
    }
    .journey-overview a:hover {
      border-color: color-mix(in srgb, var(--nbg-accent) 50%, var(--nbg-hairline));
      background: color-mix(in srgb, var(--nbg-accent) 4%, var(--nbg-surface));
      transform: translateY(-1px);
    }
    .journey-overview a:focus-visible {
      outline: 2px solid var(--nbg-accent);
      outline-offset: 2px;
    }
    .journey-overview li[data-current='true'] a {
      border-color: var(--nbg-accent);
      background: color-mix(in srgb, var(--nbg-accent) 8%, var(--nbg-surface));
    }
    .journey-overview__num {
      font-family: var(--nbg-ff-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.08em;
      color: var(--nbg-accent);
      font-weight: 600;
      padding-top: 0.1rem;
      flex: 0 0 auto;
    }
    .journey-overview__label {
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      line-height: 1.3;
      color: var(--nbg-ink);
      letter-spacing: -0.005em;
    }
    @media (max-width: 75rem) {
