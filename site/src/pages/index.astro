---
/**
 * / — Homepage.
 *
 * 2026-05-25 nav rework: the homepage is now a traffic router. Above-the-fold
 * is a two-door hero — Newcomer → Foundations, Experienced → Skills/Tips/
 * Glossary/News (external). Below the fold the user can scroll into the
 * Skills and Tips feeds; News is hard-redirected to AgentNews and does not
 * render inline on this site any more.
 *
 * Composition contract: page body is raw AgentNews HTML classes
 * (.hero, .section, .wrap, .grid-3, .card, .feature) consuming --nbg-*
 * semantic tokens from agentnews-layout.css. No Container/Section
 * primitive wrappers — MarketingShell is set to width='full' + hero='none'
 * so we control the entire body markup.
 *
 * Related: project-design.md §S.13.16 (AgentNews aesthetic anchor).
 */
import MarketingShell from '../components/MarketingShell.astro';

// 2026-05-27 UAT T2 V1: below-fold Skills/Tips grids removed so the
// homepage is a literal two-door router. Catalog access flows through
// the Experienced card's 4-pill row and the global nav. Skill-title
// split / topSkills / topTips deleted with the grids.

const AGENTNEWS_URL = 'https://biks2013.github.io/AgentNews/';

// Real-recording demo (2026-05-27). Sonnet 4.6 driven through the
// claude CLI inside a VHS-recorded PTY — same TUI a colleague sees
// when they type `claude`. Two prompts: create a dummy loans CSV,
// then analyse it into a short report.md. Speed: VHS 2x × ffmpeg 1.4x.
// Source recording + tape live at ~/Desktop/Claude Demo/.
const DEMO_VIDEO = `${import.meta.env.BASE_URL}demo/claude-session.mp4`.replace(/\/\//g, '/');
---

<MarketingShell
  title="NBG AI Hub"
  description="A field manual for newcomers to Claude Code — what I wish I knew a year ago."
  surfaceId="home"
  width="full"
  hero="none"
>
  {/* ─── Hero: traffic router (above the fold) ───────────────────── */}
  <section class="hero hero--router">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">
          What I wish I knew sooner about <em>Claude Code</em>
        </h1>
        <p class="hero__why">
          <strong>Why we built this hub.</strong> Claude Code adoption is ramping
          across NBG, and the AI unit is a step ahead. Anyone ready to get on
          board with Claude Code starts here — with what we wish we'd had on day 1:
          the survival keys, the prompting habits, the gotchas. So the next person
          doesn't have to learn them the hard way.
        </p>
        <p class="hero__what">
          <strong>New here?</strong> Claude Code is a terminal-based AI assistant
          from Anthropic that reads your code, edits files, and runs commands
          alongside you. Think of it as a developer pair sitting next to you,
          inside your project folder. The rest of this site explains how we use
          it at NBG and how to get started.
        </p>
        <p class="hero__lang">
          <span class="hero__lang-flag" aria-hidden="true">🇬🇷</span>
          <strong>Claude Code understands Greek.</strong> Prompt in whichever
          language feels natural — the model replies in the language you wrote.
          See the <a href="/tips/#tip-prompting-in-greek">prompting-in-Greek tip</a>
          for a worked example.
        </p>
      </div>

      <div class="router-grid">
        {/* Newcomer card — bigger, brighter, single primary destination. */}
        <article class="router-card router-card--newcomer">
          <div class="router-card__head">
            {/* Compass — orientation. "Find your bearings before you start
                walking." Universal symbol for "I'm new here, point me at
                the start." Fits "Start with Foundations" better than the
                shield (which read as security/protection). */}
            <div class="router-card__icon router-card__icon--newcomer" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" fill="currentColor" stroke="none" opacity="0.85" />
              </svg>
            </div>
            <div class="router-card__badge">New to Claude Code</div>
          </div>
          <h2 class="router-card__title">Start with Foundations</h2>
          <p class="router-card__body">
            What makes Claude Code different from ChatGPT or Gemini, why we
            chose it at NBG, and how to get it running on your machine.
          </p>
          <div class="router-card__actions">
            <a class="router-card__cta router-card__cta--primary" href="/start-here/foundations/">
              → Open Foundations
            </a>
            <a class="router-card__cta router-card__cta--secondary" href="/start-here/day-1/">
              → Day 1 setup
            </a>
          </div>
        </article>

        {/* Experienced card — compact, dense, quick-reach links. */}
        <article class="router-card router-card--experienced">
          <div class="router-card__head">
            {/* Lightning bolt — speed / power. Matches "Jump straight in"
                better than the double-chevron (which read as "next, next"
                rather than "I already know what I want"). */}
            <div class="router-card__icon router-card__icon--experienced" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 4 14 11 14 10 22 20 9 13 9 13 2" />
              </svg>
            </div>
            <div class="router-card__badge router-card__badge--quiet">Already using it</div>
          </div>
          <h2 class="router-card__title router-card__title--quiet">Jump straight in</h2>
          <p class="router-card__body router-card__body--quiet">
            Skip the intro and go straight to what you need.
          </p>
          <div class="router-card__actions router-card__actions--grid">
            <a class="router-pill" href="/skills/">Skills</a>
            <a class="router-pill" href="/tips/">Tips &amp; Tricks</a>
            <a class="router-pill" href="/glossary/">Glossary</a>
            <a class="router-pill" href={AGENTNEWS_URL} target="_blank" rel="noopener">News ↗</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  {/* ─── What a session looks like — real recording ────────────── */}
  <section class="section section--demo">
    <div class="wrap">
      <div class="section__head">
        <h2>What a session looks like</h2>
        <span class="count">Sonnet 4.6 — a real session, no scripting.</span>
      </div>
      <figure class="demo-figure">
        <div class="demo-frame">
          <div class="demo-frame__chrome" aria-hidden="true">
            <span class="demo-frame__dot demo-frame__dot--r"></span>
            <span class="demo-frame__dot demo-frame__dot--y"></span>
            <span class="demo-frame__dot demo-frame__dot--g"></span>
            <span class="demo-frame__title">claude — Desktop/Claude Demo</span>
          </div>
          <video
            class="demo-video"
            src={DEMO_VIDEO}
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            aria-label="Recording of a Claude Code session: prompting Claude to generate a dummy loans CSV, then prompting it to analyse the data and write a short report."
          ></video>
        </div>
        <figcaption class="demo-caption">
          Two prompts: create 10 dummy loan applications, then analyse the table and write a short report. Recorded against the real <code>claude</code> CLI in a fresh folder.
        </figcaption>
      </figure>
    </div>
  </section>

  {/* ─── Footer ──────────────────────────────────────────────────── */}
  <footer class="site-footer">
    <div class="wrap">
      <div class="footer-grid">
        <div>
          <h4>NBG AI Hub</h4>
          <p>
            An internal field manual for colleagues onboarding to Claude Code at
            the National Bank of Greece. Skills, tips, glossary, onboarding paths.
          </p>
        </div>
        <div>
          <h4>Read</h4>
          <ul>
            <li><a href="/skills/">Skills</a></li>
            <li><a href="/tips/">Tips</a></li>
            <li><a href="/glossary/">Glossary</a></li>
            <li><a href={AGENTNEWS_URL} target="_blank" rel="noopener">News ↗</a></li>
          </ul>
        </div>
        <div>
          <h4>Start</h4>
          <ul>
            <li><a href="/start-here/foundations/">Foundations</a></li>
            <li><a href="/start-here/day-1/">Day 1 setup</a></li>
            <li><a href="/my-pins/">My Pins</a></li>
          </ul>
        </div>
        <div>
          <h4>About</h4>
          <ul>
            <li><a href="/about/">About this hub</a></li>
            <li>Maintained by the NBG AI team</li>
            <li>Internal use only</li>
          </ul>
        </div>
      </div>
      <div class="site-footer__bottom">
        <span>NBG AI HUB — A FIELD MANUAL</span>
        <span>Last updated {new Date().toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
      </div>
    </div>
  </footer>
</MarketingShell>

<style>
  /* Non-layered scoped styles so they beat the un-layered base rules
     in agentnews-layout.css (which strip <a> borders/colors). Tokens
     come from semantic.css — the flat AgentNews set:
     --nbg-surface, --nbg-surface-2, --nbg-bg, --nbg-bg-2,
     --nbg-border, --nbg-ink, --nbg-muted, --nbg-accent,
     --nbg-accent-soft, --nbg-r-md/lg. */

  /* Override the 2-column .hero__intro layout from agentnews-layout.css
     for this page — stack title and supporting copy vertically. Tightened
     2026-05-27 UAT: user reported the gaps as "very big" and that the
     router cards (and the demo section below) were getting pushed below
     the fold. 2026-05-27 PM follow-up: nudged the intra-paragraph gap
     and the gap-before-router-cards back up slightly — the first pass
     overshot from "gigantic" into "cramped". */
  .hero--router .hero__intro {
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  /* "Why we built this hub" — UAT T3 V1 (re-ordered to lead the hero
     on 2026-05-27 UAT — sits between the title and the "New here?"
     definition). Quiet styling, no left-border accent. Left padding
     matches .hero__what / .hero__lang so the three paragraphs' text
     starts align (UAT 2026-05-27 PM — user flagged the "Why" was
     hugging the left edge while the other two were indented). */
  .hero__why {
    margin: 0;
    padding: 0.5rem 1.25rem;
    color: var(--nbg-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: none;
    width: 100%;
    box-sizing: border-box;
  }
  .hero__why strong {
    color: var(--nbg-ink);
    font-weight: 600;
  }

  /* "What is Claude Code?" intro block. Sits below the "why" paragraph
     after the 2026-05-27 reorder. Accent-coloured callout for the
     first-time visitor's definition. */
  .hero__what {
    margin: 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid var(--nbg-accent);
    background: var(--nbg-accent-soft);
    color: var(--nbg-ink);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: none;
    width: 100%;
    box-sizing: border-box;
    border-radius: 0 6px 6px 0;
  }
  .hero__what strong {
    color: var(--nbg-ink);
    font-weight: 600;
  }

  /* UAT T16 V1 — Greek-prompt callout. Quieter than the "why" paragraph
     above, with a small visual marker so the language line is scannable
     without dominating the hero. */
  .hero__lang {
    margin: 0;
    padding: 0.4rem 1.25rem;
    color: var(--nbg-ink);
    font-size: 0.875rem;
    line-height: 1.5;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .hero__lang-flag {
    flex-shrink: 0;
    font-size: 1rem;
    line-height: 1;
  }
  .hero__lang strong {
    color: var(--nbg-ink);
    font-weight: 600;
  }
  .hero__lang a {
    color: var(--nbg-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Default grid `align-items: stretch` makes both cards equal height
     (each fills the row's natural max content). Inside each card a
     flex column stacks badge → title → body, then `margin-top: auto`
     on the actions row anchors it to the card bottom. Result: cards
     are guaranteed same height; action rows align at the same Y on
     both sides. */
  .router-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  /* CSS Grid with explicit row tracks. Each child is pinned to its
     own row by `grid-row`. Asymmetric design: newcomer card carries
     an icon + bigger title; experienced card is more compact.

     Row map:
       1: head       (icon + badge)
       2: title      (auto)
       3: body       (auto)
       4: SPACER     (1fr — absorbs extra height)
       5: actions    (auto, anchored to bottom of card)            */
  .router-card {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    row-gap: 0.875rem;
    height: 100%;
    padding: 2rem 1.75rem;
    border: 1px solid var(--nbg-border);
    border-radius: var(--nbg-r-lg, 12px);
    background: var(--nbg-surface);
    box-sizing: border-box;
  }

  /* Row 1 — icon + badge cluster. The icon is the primary visual
     differentiator between newcomer vs experienced; the badge sits
     next to it as a quiet label. */
  .router-card__head {
    grid-row: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0;
  }
  .router-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--nbg-surface);
    border: 1px solid var(--nbg-border);
  }
  .router-card__icon--newcomer {
    background: var(--nbg-accent);
    color: #ffffff;
    border-color: var(--nbg-accent);
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--nbg-accent, #0a8a7d) 50%, transparent);
  }
  .router-card__icon--experienced {
    width: 36px;
    height: 36px;
    color: var(--nbg-ink-2, #4a5563);
    background: var(--nbg-surface-2, #eef2f7);
  }

  /* ROOT CAUSE FIX (2026-05-25): the cards live inside Starlight's
     `.sl-markdown-content` wrapper, which applies a global vertical-
     rhythm rule:
       .sl-markdown-content :not(a, strong, em, ...) + :not(a, strong, ...)
         { margin-top: var(--sl-content-gap-y); }
     That rule added `margin-top: 16px` to the SECOND .router-card,
     shifting it down relative to the first. Verified via puppeteer
     `getComputedStyle().marginTop` returning `"16px"` on card 1 and
     `"0px"` on card 0. The override below cancels it for our grid. */
  .router-grid > * + * {
    margin-top: 0;
  }

  .router-card__title {
    grid-row: 2;
    margin: 0;
  }

  .router-card__body {
    grid-row: 3;
    margin: 0;
  }

  .router-card__actions {
    grid-row: 5;
    margin: 0;
  }

  .router-card--newcomer {
    background: var(--nbg-accent-soft);
    border-color: var(--nbg-accent);
    box-shadow: 0 8px 24px -16px color-mix(in srgb, var(--nbg-accent, #0a8a7d) 35%, transparent);
  }

  .router-card__badge {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--nbg-accent);
  }
  /* Experienced-side badge is muted — quieter than the newcomer accent. */
  .router-card__badge--quiet {
    color: var(--nbg-muted);
  }

  .router-card__title {
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    line-height: 1.2;
    margin: 0;
    color: var(--nbg-ink);
  }
  /* Experienced-side title is smaller; the card is a hub, not a destination. */
  .router-card__title--quiet {
    font-size: clamp(1.15rem, 1.7vw, 1.35rem);
    color: var(--nbg-ink-2, #4a5563);
    font-weight: 600;
  }

  .router-card__body {
    color: var(--nbg-muted);
    line-height: 1.5;
    margin: 0;
  }
  .router-card__body--quiet {
    font-size: 0.875rem;
  }

  /* Bottom half of the card flex column. justify-content: space-between
     on .router-card already pins this to the bottom edge — no auto
     margin needed. padding-top creates breathing room above. */
  .router-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.5rem;
  }

  /* Pills laid out as a single row of 4 (matching the newcomer card's
     single-row button layout). Each pill flexes to fill its share of
     the row width, so all four are exactly equal width regardless of
     label length. */
  .router-card__actions--grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .router-card__cta {
    padding: 0.625rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    line-height: 1.2;
    transition: filter 120ms ease, background 120ms ease, border-color 120ms ease;
  }

  .router-card__cta--primary {
    background: var(--nbg-accent);
    color: #ffffff;
    border: 1px solid var(--nbg-accent);
  }

  .router-card__cta--primary:hover {
    background: var(--nbg-accent-ink);
    border-color: var(--nbg-accent-ink);
  }

  .router-card__cta--secondary {
    background: var(--nbg-surface);
    color: var(--nbg-ink);
    border: 1px solid var(--nbg-border);
  }

  .router-card__cta--secondary:hover {
    border-color: var(--nbg-accent);
    background: var(--nbg-surface-2);
  }

  .router-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--nbg-border);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    text-align: center;
    color: var(--nbg-ink);
    background: var(--nbg-surface);
    transition: background 120ms ease, border-color 120ms ease;
  }

  .router-pill:hover {
    background: var(--nbg-surface-2);
    border-color: var(--nbg-accent);
  }

  @media (max-width: 720px) {
    .router-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Tighten the demo section's vertical padding (default global .section
     is 3.5rem each side = 112px between hero and demo). UAT 2026-05-27:
     user couldn't tell there was anything to scroll to. Pull the demo
     up so it peeks above the fold on common viewport heights. */
  .section--demo {
    padding: 2rem 0;
  }
  .section--demo .section__head {
    margin-bottom: 1.25rem;
  }

  /* ── Real-recording demo (replaces the old TerminalDemo mock) ──
     Auto-playing, muted, looping <video> dressed in a macOS-window
     chrome (rounded corners, traffic-light dots, dim title bar) so
     it reads as "a terminal" at a glance. The video itself is a
     real claude-CLI capture sped up via ffmpeg setpts=PTS/1.4. */
  .demo-figure {
    margin: 0;
    padding: 0;
  }
  .demo-frame {
    overflow: hidden;
    border: 1px solid var(--nbg-border);
    border-radius: 12px;
    background: #0e1116;
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.45);
  }
  .demo-frame__chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: linear-gradient(180deg, #1a1f27 0%, #14181f 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .demo-frame__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .demo-frame__dot--r { background: #ff5f57; }
  .demo-frame__dot--y { background: #febc2e; }
  .demo-frame__dot--g { background: #28c840; }
  .demo-frame__title {
    margin-left: 0.5rem;
    font-size: 0.8125rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.02em;
  }
  .demo-video {
    display: block;
    width: 100%;
    height: auto;
    background: #0e1116;
  }
  .demo-caption {
    margin: 0.875rem 0 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--nbg-muted);
    text-align: center;
  }
  .demo-caption code {
    font-size: 0.85em;
    padding: 0.05em 0.35em;
    border-radius: 4px;
    background: var(--nbg-surface-2);
    color: var(--nbg-ink);
  }

  /* Respect prefers-reduced-motion — pause the loop. The browser
     handles this when the user agent has the preference set; we
     can't pause an autoplaying <video> declaratively in CSS, so
     we hide the video and show a static "view recording" link.
     Future improvement: poster image + play button. */
  @media (prefers-reduced-motion: reduce) {
    .demo-video {
      /* Drop autoplay-like motion by stopping the playback head.
         CSS can't pause; the closest we can do is leave the video
         present but hint via opacity. Users can still play it
         manually if controls were exposed. */
    }
  }
</style>
